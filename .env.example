# Copie para .env (docker-compose carrega no serviço app).

# --- Resend (e-mail) ---
RESEND_API_KEY=your_resend_api_key

# Domínio base (sem subdomínio do tenant).
# Dev local: lvh.me  →  http://objetivo.lvh.me:3000
# Produção: connect.coupons  →  https://objetivo.connect.coupons
MAILER_HOST_BASE=lvh.me

# Remetente
# Dev (sem domínio verificado no Resend): onboarding@resend.dev
# Produção (após verificar connect.coupons no Resend):
# MAILER_FROM="Alpha White <noreply@connect.coupons>"

MAILER_FROM="Alpha White <onboarding@resend.dev>"
