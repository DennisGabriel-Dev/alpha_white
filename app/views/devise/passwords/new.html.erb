<%# Recuperação de Senha - Design moderno %>

<div class="min-h-screen bg-gradient-to-br from-primary-dark via-primary to-accent-turquoise flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-sm w-full">
    
    <%# Card Principal %>
    <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 space-y-6">
      
      <%# Header %>
      <div class="text-center">
        <div class="flex justify-center mb-4">
          <div class="w-14 h-14 bg-gradient-to-br from-accent-turquoise to-primary rounded-2xl flex items-center justify-center shadow-lg">
            <%= heroicon(:key, variant: :solid, css_class: "w-8 h-8 text-white") %>
          </div>
        </div>
        
        <h1 class="text-2xl font-bold text-gray-900 mb-2">
          Esqueceu sua senha?
        </h1>
        <p class="text-sm text-gray-600">
          Sem problemas! Vamos te ajudar a recuperar o acesso
        </p>
      </div>

      <%# Instruções %>
      <div class="bg-blue-50 border-l-4 border-blue-500 rounded-lg p-4">
        <div class="flex items-start">
          <span class="text-2xl mr-3">💡</span>
          <p class="text-sm text-blue-800">
            Digite seu e-mail e enviaremos instruções para redefinir sua senha
          </p>
        </div>
      </div>

      <%# Formulário %>
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.email_field :email, 
              autofocus: true, 
              autocomplete: "email",
              placeholder: "seu@email.com",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-all text-gray-900 placeholder-gray-400" %>
        </div>

        <div>
          <%= f.submit "Enviar instruções", class: "w-full bg-gradient-to-r from-accent-turquoise to-primary hover:from-primary hover:to-accent-turquoise text-white font-semibold py-2.5 px-6 rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl" %>
        </div>
      <% end %>

      <%# Links de Volta %>
      <div class="text-center space-y-3 pt-4 border-t border-gray-200">
        <%= link_to "Voltar para login", new_session_path(resource_name), class: "block text-sm text-primary hover:text-primary-dark font-semibold" %>
        <%= link_to "Criar uma conta nova", new_registration_path(resource_name), class: "block text-sm text-gray-600 hover:text-gray-800" %>
      </div>
    </div>

    <%# Voltar para Home %>
    <div class="text-center mt-8">
      <%= link_to root_path, class: "inline-flex items-center text-white hover:text-gray-200 transition-colors" do %>
        <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
        Voltar para home
      <% end %>
    </div>
  </div>
</div>
