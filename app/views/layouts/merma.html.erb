<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "#{tenant_name} – #{tenant_tagline}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= render "shared/tenant_head" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --color-primary:       <%= tenant_primary_color %>;
        --color-primary-dark:  color-mix(in srgb, <%= tenant_primary_color %> 80%, black);
        --color-primary-10:    color-mix(in srgb, <%= tenant_primary_color %> 10%, white);
        --color-primary-20:    color-mix(in srgb, <%= tenant_primary_color %> 20%, white);
      }

      body { font-family: 'Inter', sans-serif; }

      /* ── Rail ── */
      .merma-rail-btn {
        width: 2.25rem; height: 2.25rem;
        border-radius: .625rem;
        display: flex; align-items: center; justify-content: center;
        color: #9ca3af;
        transition: background .15s, color .15s;
      }
      .merma-rail-btn:hover { background: #f3f4f6; color: #374151; }
      .merma-rail-btn.active { background: var(--color-primary-10); color: var(--color-primary); }

      /* ── Sidebar nav items ── */
      .merma-nav-item {
        display: flex; align-items: center; gap: .625rem;
        padding: .4rem .75rem; border-radius: .5rem;
        font-size: .8125rem; color: #374151; cursor: pointer;
        transition: background .15s;
        text-decoration: none;
      }
      .merma-nav-item:hover { background: #f3f4f6; }
      .merma-nav-item.active { background: var(--color-primary-10); color: var(--color-primary); font-weight: 600; }

      /* ── Merma primary button ── */
      .merma-btn-primary {
        background: var(--color-primary); color: #fff;
        border-radius: .75rem; font-weight: 600;
        transition: background .15s;
      }
      .merma-btn-primary:hover { background: var(--color-primary-dark); }

      /* ── Progress ring text ── */
      .merma-ring-text { font-family: 'Inter', sans-serif; font-weight: 700; }
    </style>
  </head>

  <body class="bg-white font-sans antialiased h-screen overflow-hidden flex">

    <% unless auth_minimal_chrome? %>
    <%# ══ Rail esquerda (ícones) ══ %>
    <nav class="w-14 bg-white border-r border-gray-200 flex flex-col items-center pt-4 pb-3 flex-shrink-0 z-10">

      <%# Logo badge %>
      <div class="w-9 h-9 rounded-xl flex items-center justify-center text-white text-sm font-bold mb-5 flex-shrink-0"
           style="background: var(--color-primary);">
        <% if tenant_logo_url.present? %>
          <img src="<%= tenant_logo_url %>" alt="<%= tenant_name %>" class="w-full h-full rounded-xl object-cover">
        <% else %>
          <%= tenant_name.first.upcase %>
        <% end %>
      </div>

      <%# Nav principal %>
      <div class="flex flex-col items-center gap-1 flex-1 w-full px-2">
        <%= link_to root_path,
              title: "Início",
              class: "merma-rail-btn #{current_page?(root_path) ? 'active' : ''}" do %>
          <svg class="w-4.5 h-4.5 w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        <% end %>

        <%= link_to courses_path,
              title: "Cursos",
              class: "merma-rail-btn #{controller_name == 'courses' ? 'active' : ''}" do %>
          <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        <% end %>

        <% if admin_or_instructor? %>
          <div class="w-full px-0 my-1 border-t border-gray-100"></div>
          <%= link_to new_course_path,
                title: "Novo curso",
                class: "merma-rail-btn" do %>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          <% end %>
        <% end %>
      </div>

      <%# Bottom: settings + avatar %>
      <div class="flex flex-col items-center gap-2 px-2 w-full">
        <% if super_admin? || tenant_admin? %>
          <%= link_to edit_tenant_setting_path,
                title: "Aparência",
                class: "merma-rail-btn #{controller_name == 'tenant_settings' ? 'active' : ''}" do %>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
                title: "Sair (#{current_user.email})",
                class: "merma-rail-btn" do %>
            <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold text-white"
                 style="background: var(--color-primary);">
              <%= current_user.email.first.upcase %>
            </div>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, title: "Entrar", class: "merma-rail-btn" do %>
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
            </svg>
          <% end %>
        <% end %>
      </div>
    </nav>

    <div id="merma-sidebar-backdrop"
         class="fixed inset-0 bg-black/40 z-30 lg:hidden hidden"
         aria-hidden="true"></div>

    <%# ══ Sidebar contextual (drawer &lt; lg) ══ %>
    <aside id="merma-context-sidebar"
           class="fixed inset-y-0 left-14 z-40 w-56 max-w-[85vw] bg-gray-50 border-r border-gray-200 flex flex-col overflow-hidden flex-shrink-0
                  -translate-x-full lg:static lg:left-auto lg:z-auto lg:max-w-none lg:translate-x-0
                  transition-transform duration-200 ease-out"
           data-drawer-closed-class="-translate-x-full"
           data-drawer-open-class="translate-x-0">
      <% if content_for?(:sidebar_content) %>
        <%= yield :sidebar_content %>
      <% else %>
        <%= render "shared/merma/context_sidebar" %>
      <% end %>
    </aside>
    <% end %>

    <%# ══ Área de conteúdo ══ %>
    <div class="flex-1 flex overflow-hidden min-w-0">

      <%# Coluna principal %>
      <div class="flex-1 flex flex-col overflow-hidden bg-white min-w-0">

        <% unless auth_minimal_chrome? %>
        <%# Header %>
        <header class="border-b border-gray-100 px-4 sm:px-6 py-3 flex items-center justify-between flex-shrink-0 min-h-[3.25rem] gap-2">
          <div class="flex items-center gap-2 min-w-0 flex-1">
            <%= render "shared/drawer_menu_button",
                  toggle_id: "merma-context-sidebar",
                  backdrop_id: "merma-sidebar-backdrop",
                  label: "Navegação" %>
            <% if content_for?(:breadcrumb) %>
              <%= yield :breadcrumb %>
            <% elsif content_for?(:header_title) %>
              <h1 class="text-sm font-semibold text-gray-800 truncate"><%= yield :header_title %></h1>
            <% end %>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <% if content_for?(:right_panel) %>
              <button type="button"
                      class="xl:hidden px-2.5 py-1.5 text-xs font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors flex-shrink-0"
                      data-drawer-toggle="merma-right-panel"
                      data-drawer-backdrop="merma-panel-backdrop"
                      aria-expanded="false"
                      aria-label="Painel lateral">
                Progresso
              </button>
            <% end %>
            <% if content_for?(:header_actions) %>
              <%= yield :header_actions %>
            <% end %>
            <% if user_signed_in? && tenant_feature?(:gamification) %>
              <%= render "shared/student_streak_badge" %>
              <span class="text-xs text-gray-400 hidden sm:block truncate max-w-[10rem]"><%= current_user.email %></span>
            <% end %>
          </div>
        </header>
        <% end %>

        <%# Flash messages %>
        <% if notice.present? || alert.present? %>
          <div class="px-6 pt-3">
            <% if notice.present? %>
              <div class="rounded-xl bg-green-50 border border-green-200 px-4 py-2.5 text-green-800 text-sm mb-2"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="rounded-xl bg-red-50 border border-red-200 px-4 py-2.5 text-red-800 text-sm mb-2"><%= alert %></div>
            <% end %>
          </div>
        <% end %>

        <%# Conteúdo da página %>
        <main class="flex-1 <%= content_for?(:main_class) ? yield(:main_class) : 'overflow-y-auto' %>">
          <%= yield %>
        </main>

      </div>

      <%# Painel direito (opcional, drawer &lt; xl) %>
      <% if content_for?(:right_panel) %>
        <div id="merma-panel-backdrop"
             class="fixed inset-0 bg-black/40 z-30 xl:hidden hidden"
             aria-hidden="true"></div>
        <aside id="merma-right-panel"
               class="fixed inset-y-0 right-0 z-40 w-72 max-w-[90vw] border-l border-gray-200 flex flex-col overflow-y-auto flex-shrink-0 bg-white
                      translate-x-full xl:static xl:z-auto xl:max-w-none xl:translate-x-0
                      transition-transform duration-200 ease-out"
               data-drawer-closed-class="translate-x-full"
               data-drawer-open-class="translate-x-0">
          <%= yield :right_panel %>
        </aside>
      <% end %>

    </div>

    <%= render "shared/drawer_toggle_script" unless auth_minimal_chrome? %>
  </body>
</html>
