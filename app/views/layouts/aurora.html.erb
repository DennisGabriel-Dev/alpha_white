<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "#{tenant_name} - #{tenant_tagline}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= render "shared/tenant_head" %>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --color-primary: <%= tenant_primary_color %>;
        --color-primary-dark: color-mix(in srgb, <%= tenant_primary_color %> 80%, black);
        --color-primary-light: color-mix(in srgb, <%= tenant_primary_color %> 15%, white);
      }

      .aurora-sidebar {
        background-color: var(--color-primary);
      }

      .aurora-sidebar-link.active,
      .aurora-sidebar-link:hover {
        background-color: var(--color-primary-dark);
      }

      .aurora-logo-badge {
        background-color: var(--color-primary-dark);
      }

      .aurora-btn-primary {
        background-color: var(--color-primary);
        color: #fff;
      }

      .aurora-btn-primary:hover {
        background-color: var(--color-primary-dark);
      }
    </style>
  </head>

  <body class="bg-gray-50 font-sans antialiased">
    <div class="flex h-screen overflow-hidden">

      <% unless auth_minimal_chrome? %>
      <div id="aurora-sidebar-backdrop"
           class="fixed inset-0 bg-black/40 z-30 lg:hidden hidden"
           aria-hidden="true"></div>

      <%# ── Sidebar (drawer &lt; lg) ── %>
      <aside id="aurora-sidebar"
             class="aurora-sidebar fixed inset-y-0 left-0 z-40 w-56 max-w-[85vw] flex-shrink-0 flex flex-col text-white
                    -translate-x-full lg:static lg:z-auto lg:max-w-none lg:translate-x-0
                    transition-transform duration-200 ease-out"
             data-drawer-closed-class="-translate-x-full"
             data-drawer-open-class="translate-x-0">

        <%# Logo %>
        <div class="flex items-center gap-3 px-5 py-5 border-b border-white/10">
          <% if tenant_logo_url.present? %>
            <img src="<%= tenant_logo_url %>" alt="<%= tenant_name %>" class="h-8 w-8 rounded-lg object-cover">
          <% else %>
            <div class="aurora-logo-badge h-8 w-8 rounded-lg flex items-center justify-center text-white font-bold text-sm">
              <%= tenant_name.first.upcase %>
            </div>
          <% end %>
          <span class="font-semibold text-sm leading-tight"><%= tenant_name %></span>
        </div>

        <%# Navigation %>
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
          <p class="px-2 text-xs font-semibold text-white/40 uppercase tracking-widest mb-2">Principal</p>

          <%= link_to root_path,
                class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{current_page?(root_path) ? 'active' : ''}" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Visão geral
          <% end %>

          <%= link_to courses_path,
                class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'courses' ? 'active' : ''}" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            Cursos
          <% end %>

          <% if me_achievements_path_allowed? %>
            <p class="px-2 text-xs font-semibold text-white/40 uppercase tracking-widest mb-2 mt-4">Você</p>
            <%= link_to me_achievements_path,
                  class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_path == 'me/achievements' ? 'active' : ''}" do %>
              <%= heroicon(:trophy, css_class: "w-4 h-4 flex-shrink-0") %>
              <span class="flex-1">Conquistas</span>
            <% end %>
          <% end %>

          <% if reports_aluno_path_allowed? || reports_turma_path_allowed? || reports_escola_path_allowed? %>
            <p class="px-2 text-xs font-semibold text-white/40 uppercase tracking-widest mb-2 mt-4">Relatórios</p>
            <% if reports_aluno_path_allowed? %>
              <%= link_to relatorios_aluno_path,
                    class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'reports' && action_name == 'aluno' ? 'active' : ''}" do %>
                <%= heroicon(:chart_bar, css_class: "w-4 h-4 flex-shrink-0") %>
                Meu desempenho
              <% end %>
            <% end %>
            <% if reports_turma_path_allowed? %>
              <%= link_to relatorios_turma_path,
                    class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'reports' && action_name == 'turma' ? 'active' : ''}" do %>
                <%= heroicon(:user_group, css_class: "w-4 h-4 flex-shrink-0") %>
                Turma
              <% end %>
            <% end %>
            <% if reports_escola_path_allowed? %>
              <%= link_to relatorios_escola_path,
                    class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'reports' && action_name == 'escola' ? 'active' : ''}" do %>
                <%= heroicon(:building_office, css_class: "w-4 h-4 flex-shrink-0") %>
                Escola
              <% end %>
            <% end %>
          <% end %>

          <% if staff_users_path_allowed? %>
            <p class="px-2 text-xs font-semibold text-white/40 uppercase tracking-widest mb-2 mt-4">Administração</p>
            <%= link_to staff_users_path,
                  class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'staff_users' ? 'active' : ''}" do %>
              <%= heroicon(:users, css_class: "w-4 h-4 flex-shrink-0") %>
              Equipe
            <% end %>
          <% end %>

          <p class="px-2 text-xs font-semibold text-white/40 uppercase tracking-widest mb-2 mt-4">Biblioteca</p>

          <% if tenant_admin? %>
            <%= link_to edit_tenant_setting_path,
                  class: "aurora-sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/80 transition-colors #{controller_name == 'tenant_settings' ? 'active' : ''}" do %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Aparência
            <% end %>
          <% end %>
        </nav>

        <%# User footer %>
        <% if user_signed_in? %>
          <div class="border-t border-white/10 px-4 py-4 flex items-center gap-3">
            <div class="aurora-logo-badge h-8 w-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
              <%= current_user.email.first.upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-medium text-white truncate"><%= current_user.email %></p>
              <p class="text-xs text-white/50"><%= current_user.role.humanize %></p>
            </div>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
                  class: "text-white/40 hover:text-white transition-colors flex-shrink-0",
                  title: "Sair" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </aside>
      <% end %>

      <%# ── Main area ── %>
      <div class="flex-1 flex flex-col overflow-hidden min-w-0">

        <% unless auth_minimal_chrome? %>
        <%# Header %>
        <header class="bg-white border-b border-gray-100 px-4 sm:px-6 py-3 flex items-center justify-between flex-shrink-0 gap-2">
          <div class="flex items-center gap-2 sm:gap-6 min-w-0 flex-1">
            <%= render "shared/drawer_menu_button",
                  toggle_id: "aurora-sidebar",
                  backdrop_id: "aurora-sidebar-backdrop",
                  label: "Menu principal" %>
            <% if content_for?(:header_title) %>
              <div class="min-w-0">
                <h1 class="text-sm font-semibold text-gray-900 truncate"><%= yield :header_title %></h1>
                <% if content_for?(:header_subtitle) %>
                  <p class="text-xs text-gray-400 truncate"><%= yield :header_subtitle %></p>
                <% end %>
              </div>
            <% end %>
            <%= yield :header_actions if content_for?(:header_actions) %>
          </div>

          <div class="flex items-center gap-3">
            <%# Search %>
            <div class="relative hidden sm:block">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <input type="text" placeholder="Buscar cursos..."
                     class="pl-9 pr-4 py-1.5 text-sm bg-gray-50 border border-gray-200 rounded-lg w-48 focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent">
            </div>

            <% if user_signed_in? && tenant_feature?(:gamification) %>
              <%= render "shared/student_streak_badge" %>
            <% end %>

            <%# Notification bell %>
            <button class="relative p-1.5 text-gray-400 hover:text-gray-600 transition-colors rounded-lg hover:bg-gray-100">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
            </button>
          </div>
        </header>
        <% end %>

        <%# Flash messages %>
        <% if notice.present? || alert.present? %>
          <div class="px-6 pt-4">
            <% if notice.present? %>
              <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-green-800 text-sm mb-2">
                <%= notice %>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm mb-2">
                <%= alert %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Page content %>
        <main class="flex-1 <%= content_for?(:main_class) ? yield(:main_class) : 'overflow-y-auto' %>">
          <%= yield %>
        </main>

      </div>
    </div>

    <%= render "shared/drawer_toggle_script" unless auth_minimal_chrome? %>
  </body>
</html>
