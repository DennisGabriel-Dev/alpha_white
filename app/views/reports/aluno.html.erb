<% content_for :title, "Relatórios — Meu desempenho" %>
<% if themed_layout? %>
  <% content_for :header_title, "Meu desempenho" %>
<% end %>

<%= render "shared/header" unless themed_layout? %>

<div class="<%= themed_layout? ? 'max-w-3xl mx-auto px-5 py-6' : 'container mx-auto px-4 py-8 max-w-4xl' %>">
  <nav class="mb-6"><%= render "reports/nav" %></nav>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Progresso por curso</h2>
    <% if @data.course_rows.empty? %>
      <p class="text-sm text-gray-500">Nenhum curso ativo ou ainda sem aulas cadastradas.</p>
    <% else %>
      <div class="space-y-4">
        <% @data.course_rows.each do |row| %>
          <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex justify-between gap-3 mb-2">
              <%= link_to row.course.name, course_path(row.course), class: "font-medium text-gray-900 hover:text-primary truncate" %>
              <span class="text-sm text-gray-600 flex-shrink-0"><%= row.completed %> / <%= row.total %> aulas</span>
            </div>
            <%= render "reports/progress_bar", percent: row.percent %>
            <p class="text-xs text-gray-500 mt-1"><%= number_to_percentage(row.percent, precision: 1, strip_insignificant_zeros: true) %> concluído</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Desempenho em questões ENEM</h2>
    <p class="text-sm text-gray-500 mb-3">Somente questões de provas importadas da biblioteca ENEM (com vínculo oficial).</p>
    <% if @data.enem_rows.empty? %>
      <p class="text-sm text-gray-500">Você ainda não respondeu questões vinculadas ao ENEM.</p>
    <% else %>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 text-left text-gray-600">
            <tr>
              <th class="px-4 py-2">Área</th>
              <th class="px-4 py-2 text-right">Acertos</th>
              <th class="px-4 py-2 text-right">Total</th>
              <th class="px-4 py-2 w-40">Taxa</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @data.enem_rows.each do |row| %>
              <tr>
                <td class="px-4 py-2 font-medium text-gray-900"><%= reports_area_label(row.area) %></td>
                <td class="px-4 py-2 text-right tabular-nums"><%= row.correct %></td>
                <td class="px-4 py-2 text-right tabular-nums"><%= row.total %></td>
                <td class="px-4 py-2">
                  <%= render "reports/progress_bar", percent: row.percent %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
</div>
