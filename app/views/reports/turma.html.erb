<% content_for :title, "Relatórios — Turma" %>
<% if themed_layout? %>
  <% content_for :header_title, "Turma" %>
  <% content_for :breadcrumb do %>
    <%= render "shared/reports_breadcrumb", title: "Turma" %>
  <% end %>
<% end %>

<%= render "shared/header" unless themed_layout? %>

<div class="<%= theme_page_container_class(max_width: '5xl') %>">
  <%= render "reports/nav" %>

  <% if reports_turma_path_allowed? %>
    <%= render "reports/csv_export", courses: @courses %>
  <% end %>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Top 10 questões com mais erros</h2>
    <p class="text-sm text-gray-500 mb-3">Respostas incorretas registradas no cursinho (todas as provas).</p>
    <% if @data.top_wrong.empty? %>
      <p class="text-sm text-gray-500">Ainda não há respostas incorretas suficientes para ranquear.</p>
    <% else %>
      <div class="<%= theme_table_wrap_class %>">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 text-left text-gray-600">
            <tr>
              <th class="px-4 py-2">#</th>
              <th class="px-4 py-2">Questão (trecho)</th>
              <th class="px-4 py-2 text-right">Erros</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @data.top_wrong.each_with_index do |row, i| %>
              <tr>
                <td class="px-4 py-2 text-gray-500"><%= i + 1 %></td>
                <td class="px-4 py-2 text-gray-900"><%= truncate(row.question.enunciation, length: 120) %></td>
                <td class="px-4 py-2 text-right font-medium tabular-nums"><%= row.wrong_count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Conclusão por aluno</h2>
    <p class="text-sm text-gray-500 mb-3">Aulas consideradas “concluídas” quando vídeo (se houver) e prova (se houver) estão ok, como na plataforma.</p>
    <% if @data.student_rows.empty? %>
      <p class="text-sm text-gray-500">Nenhum aluno cadastrado ou não há aulas no cursinho.</p>
    <% else %>
      <div class="<%= theme_table_wrap_class %>">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 text-left text-gray-600">
            <tr>
              <th class="px-4 py-2">Aluno</th>
              <th class="px-4 py-2 text-right">Aulas ok</th>
              <th class="px-4 py-2 text-right">Total</th>
              <th class="px-4 py-2 text-right">Tentativas</th>
              <th class="px-4 py-2 text-right">Tempo em provas</th>
              <th class="px-4 py-2 w-40">Progresso</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @data.student_rows.each do |row| %>
              <tr>
                <td class="px-4 py-2 text-gray-900 truncate max-w-xs"><%= row.user.email %></td>
                <td class="px-4 py-2 text-right tabular-nums"><%= row.completed %></td>
                <td class="px-4 py-2 text-right tabular-nums"><%= row.total %></td>
                <td class="px-4 py-2 text-right tabular-nums"><%= row.quiz_attempts_count %></td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-600"><%= reports_format_duration(row.quiz_time_seconds) %></td>
                <td class="px-4 py-2">
                  <%= render "reports/progress_bar", percent: row.percent %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
</div>
