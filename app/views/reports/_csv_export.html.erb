<% return unless csv_export_allowed? %>
<%# Export CSV — escolha do curso + filtro de período (turma) %>
<section class="<%= theme_panel_class %> mb-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-1">Exportar CSV por curso</h2>
  <p class="text-sm text-gray-500 mb-4">
    Uma linha por aluno × questão. Deixe as datas em branco para todo o histórico.
  </p>

  <% if courses.empty? %>
    <p class="text-sm text-gray-500">Nenhum curso cadastrado.</p>
  <% else %>
    <form id="course-csv-export-form" class="flex flex-wrap items-end gap-3" method="get" data-turbo="false">
      <div>
        <label for="export_course_id" class="block text-xs font-semibold text-gray-600 mb-1">Curso</label>
        <select name="course_id" id="export_course_id" required
                class="px-3 py-2 border border-gray-300 rounded-lg text-sm min-w-[12rem] bg-white">
          <option value="">Selecione…</option>
          <% courses.each do |course| %>
            <option value="<%= course.id %>"><%= course.name %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label for="export_from" class="block text-xs font-semibold text-gray-600 mb-1">De</label>
        <input type="date" name="from" id="export_from"
               class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white">
      </div>
      <div>
        <label for="export_to" class="block text-xs font-semibold text-gray-600 mb-1">Até</label>
        <input type="date" name="to" id="export_to"
               class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white">
      </div>
      <button type="submit" class="<%= theme_btn_primary_class(extra: 'px-4 py-2') %>">Baixar CSV</button>
    </form>
  <% end %>
</section>

<script>
  document.addEventListener("turbo:load", function () {
    const form = document.getElementById("course-csv-export-form");
    if (!form) return;

    form.addEventListener("submit", function (event) {
      event.preventDefault();
      const courseId = document.getElementById("export_course_id").value;
      if (!courseId) return;

      const params = new URLSearchParams(new FormData(form));
      params.delete("course_id");
      const query = params.toString();
      const url = "/courses/" + courseId + "/relatorio" + (query ? "?" + query : "");
      window.location.assign(url);
    });
  });
</script>
