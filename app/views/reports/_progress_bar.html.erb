<%# locals: percent (0..100), bar_class (optional Tailwind for fill) %>
<% pct = [[percent.to_f, 0].max, 100].min %>
<% fill = local_assigns[:bar_class].presence || "bg-primary" %>
<div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
  <div class="<%= fill %> h-2 rounded-full transition-all" style="width: <%= pct %>%; min-width: <%= pct.positive? ? "2px" : "0" %>"></div>
</div>
