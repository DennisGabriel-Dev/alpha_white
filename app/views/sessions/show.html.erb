<%# Página da sessão com lista de aulas %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8">
  <nav class="mb-6">
    <%= link_to course_path(@course), class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
      <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
      Voltar para <%= @course.name %>
    <% end %>
  </nav>

  <% if notice %>
    <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-lg text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <div class="card mb-8">
    <h1 class="text-2xl font-bold text-gray-800"><%= @session.name %></h1>
    <p class="text-gray-500 text-sm mt-1">Sessão do curso <%= @course.name %></p>
  </div>

  <%# Aulas %>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h2 class="text-xl font-bold text-gray-800">
      Aulas
      <% if @session.lessons.any? %>
        <span class="text-gray-500 font-normal text-base ml-2">(<%= @session.lessons.count %>)</span>
      <% end %>
    </h2>
    <% if admin_or_instructor? %>
      <%= link_to new_course_session_lesson_path(@course, @session), class: "btn-primary inline-flex items-center" do %>
        <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
        Nova aula
      <% end %>
    <% end %>
  </div>

  <% if @session.lessons.any? %>
    <div class="space-y-4">
      <% @session.lessons.each_with_index do |lesson, index| %>
        <div class="card flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold">
              <%= index + 1 %>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800">
                <%= link_to lesson.name, course_session_lesson_path(@course, @session, lesson), class: "hover:text-primary transition-colors" %>
              </h3>
              <% if lesson.description.present? %>
                <p class="text-sm text-gray-600 line-clamp-1"><%= lesson.description %></p>
              <% end %>
              <div class="flex gap-2 mt-2 text-xs text-gray-500">
                <% if lesson.video_url.present? %>
                  <span class="flex items-center gap-1">
                    <%= heroicon(:play, css_class: "w-4 h-4") %>
                    Vídeo
                  </span>
                <% end %>
                <% if lesson.quiz.present? %>
                  <span class="flex items-center gap-1">
                    <%= heroicon(:chart_bar, css_class: "w-4 h-4") %>
                    Prova
                  </span>
                <% end %>
              </div>
            </div>
          </div>
          <% if admin_or_instructor? %>
            <div class="flex items-center gap-2">
              <%= link_to edit_course_session_lesson_path(@course, @session, lesson), class: "px-4 py-2 text-sm font-medium text-primary border border-primary rounded-lg hover:bg-primary/5 transition-colors" do %>
                <%= heroicon(:pencil, css_class: "w-4 h-4 inline-block mr-1") %>
                Editar
              <% end %>
              <%= button_to course_session_lesson_path(@course, @session, lesson), method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover esta aula?" }, class: "px-4 py-2 text-sm font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors" do %>
                <%= heroicon(:trash, css_class: "w-4 h-4 inline-block mr-1") %>
                Remover
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <span class="text-5xl mb-4 inline-block">📖</span>
      <h3 class="text-lg font-semibold text-gray-700 mb-2">Nenhuma aula cadastrada</h3>
      <p class="text-gray-500 mb-4">
        <%= admin_or_instructor? ? "Adicione a primeira aula para esta sessão." : "As aulas serão exibidas aqui quando forem cadastradas." %>
      </p>
      <% if admin_or_instructor? %>
        <%= link_to new_course_session_lesson_path(@course, @session), class: "btn-primary inline-flex items-center" do %>
          <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
          Nova aula
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<%= render "shared/footer" %>
