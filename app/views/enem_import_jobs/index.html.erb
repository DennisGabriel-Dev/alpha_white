<div class="container mx-auto px-4 py-8 max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Meus imports ENEM</h1>
      <p class="text-gray-500 text-sm mt-1">Envie a prova + gabarito no padrão INEP para popular o banco oficial.</p>
      <span>
        Página oficial do INEP:
        <a href="https://www.gov.br/inep/pt-br/areas-de-atuacao/avaliacao-e-exames-educacionais/enem/provas-e-gabaritos" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
          Provas e gabaritos
        </a>
      </span>
    </div>
    <%= link_to "Biblioteca ENEM", enem_exams_path, class: "px-4 py-2 rounded border border-gray-300 text-gray-700 hover:bg-gray-50" %>
  </div>

  <% if notice.present? %>
    <div class="mb-4 p-3 rounded border border-green-200 bg-green-50 text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <% if alert.present? %>
    <div class="mb-4 p-3 rounded border border-red-200 bg-red-50 text-red-800">
      <%= alert %>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
    <h2 class="font-semibold text-gray-800 mb-3">Novo import</h2>

    <%= form_with url: enem_import_jobs_path, method: :post, multipart: true, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :exam_pdf, "PDF da prova (PV)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.file_field :exam_pdf,
                         accept: ".pdf",
                         required: true,
                         class: "block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20 border border-gray-300 rounded-md bg-gray-50 p-2 focus:outline-none focus:ring-2 focus:ring-primary/40" %>
      </div>

      <div>
        <%= f.label :answer_key_pdf, "PDF do gabarito (GB)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.file_field :answer_key_pdf,
                         accept: ".pdf",
                         required: true,
                         class: "block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20 border border-gray-300 rounded-md bg-gray-50 p-2 focus:outline-none focus:ring-2 focus:ring-primary/40" %>
      </div>

      <div>
        <%= f.submit "Enviar para processamento", class: "px-4 py-2 rounded bg-primary text-white hover:opacity-90" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left px-4 py-2 font-semibold text-gray-600">ID</th>
          <th class="text-left px-4 py-2 font-semibold text-gray-600">Status</th>
          <th class="text-left px-4 py-2 font-semibold text-gray-600">Prova vinculada</th>
          <th class="text-left px-4 py-2 font-semibold text-gray-600">Criado em</th>
          <th class="text-left px-4 py-2 font-semibold text-gray-600">Erro</th>
        </tr>
      </thead>
      <tbody>
        <% if @jobs.any? %>
          <% @jobs.each do |job| %>
            <tr class="border-t border-gray-100 align-top">
              <td class="px-4 py-2"><%= job.id %></td>
              <td class="px-4 py-2"><%= job.status %></td>
              <td class="px-4 py-2">
                <% if job.enem_exam.present? %>
                  <%= link_to "#{job.enem_exam.year} #{job.enem_exam.day} #{job.enem_exam.booklet_color}",
                              enem_exam_path(job.enem_exam),
                              class: "text-primary hover:underline" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td class="px-4 py-2"><%= job.created_at.strftime("%d/%m/%Y %H:%M") %></td>
              <td class="px-4 py-2 text-red-700"><%= job.error_message.presence || "-" %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-4 py-6 text-center text-gray-500">
              Nenhum import encontrado.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
