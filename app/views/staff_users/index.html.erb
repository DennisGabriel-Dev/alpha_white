<%# Lista de instrutores do tenant %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8 max-w-3xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Equipe · Instrutores</h1>
    <%= link_to "Novo instrutor", new_staff_user_path, class: "btn-primary" %>
  </div>

  <% if @instructors.any? %>
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-gray-600">
          <tr>
            <th class="px-4 py-3 font-semibold">E-mail</th>
            <th class="px-4 py-3 font-semibold">Cadastro</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @instructors.each do |instructor| %>
            <tr>
              <td class="px-4 py-3 text-gray-800"><%= instructor.email %></td>
              <td class="px-4 py-3 text-gray-500"><%= l(instructor.created_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-600">Nenhum instrutor cadastrado ainda.</p>
  <% end %>
</div>

<%= render "shared/footer" %>
