<%= form_with model: instructor, url: staff_users_path, local: true, class: "space-y-4" do |f| %>
  <% if instructor.errors.any? %>
    <div class="p-4 bg-red-50 border-l-4 border-red-500 rounded-lg">
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% instructor.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.email_field :email,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent",
        autofocus: true, required: true %>
  </div>

  <div>
    <%= f.label :password, "Senha", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.password_field :password,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent",
        required: true, minlength: 6 %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.password_field :password_confirmation,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent",
        required: true, minlength: 6 %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= f.submit "Criar instrutor", class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancelar", staff_users_path, class: "text-gray-600 hover:text-gray-800 font-medium" %>
  </div>
<% end %>
