<%# Course card – Aurora style
    Locals: course %>

<div class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-md transition-shadow group">

  <%# Thumbnail %>
  <div class="h-36 flex items-center justify-center relative overflow-hidden"
       style="background: linear-gradient(135deg, var(--color-primary), color-mix(in srgb, var(--color-primary) 60%, black));">
    <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
    </svg>
    <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-semibold bg-white/20 text-white backdrop-blur-sm">
      <%= course.active ? "Ativo" : "Em breve" %>
    </span>
  </div>

  <%# Conteúdo %>
  <div class="p-4">
    <h3 class="font-semibold text-gray-900 text-sm leading-snug mb-1 group-hover:text-[var(--color-primary)] transition-colors">
      <%= course.name %>
    </h3>
    <p class="text-xs text-gray-400 leading-relaxed line-clamp-2 mb-4">
      <%= course.description.presence || "Conteúdo completo para sua preparação." %>
    </p>

    <% sessions_count = course.sessions.count %>
    <% lessons_count  = course.sessions.sum { |s| s.lessons.count } %>
    <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <%= pluralize(sessions_count, "módulo", "módulos") %>
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <%= pluralize(lessons_count, "aula", "aulas") %>
      </span>
    </div>

    <%= link_to course_path(course),
          class: "block w-full text-center aurora-btn-primary py-2 rounded-xl text-xs font-semibold transition-opacity hover:opacity-90" do %>
      Ver curso
    <% end %>
  </div>

</div>
