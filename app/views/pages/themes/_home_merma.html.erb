<%# Home – Merma %>
<% content_for :header_title, "Visão geral" %>

<div class="p-6 overflow-y-auto flex-1 h-full">

  <%# Saudação %>
  <div class="mb-7">
    <% greeting = Time.current.hour < 12 ? "Bom dia" : Time.current.hour < 18 ? "Boa tarde" : "Boa noite" %>
    <h1 class="text-xl font-bold text-gray-900">
      <%= greeting %><%= user_signed_in? ? ", #{current_user.email.split('@').first.capitalize}." : "." %>
    </h1>
    <p class="text-sm text-gray-400 mt-1">
      <%= user_signed_in? ? "Continue seus estudos de onde parou." : "Explore os cursos disponíveis." %>
    </p>
  </div>

  <% if user_signed_in? %>
    <%# Stats row %>
    <% total_lessons   = Course.joins(sessions: :lessons).count %>
    <% completed_count = LessonCompletion.where(user: current_user).count %>
    <% pct_overall     = total_lessons > 0 ? (completed_count * 100.0 / total_lessons).round : 0 %>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
      <% [
        { label: "Cursos ativos",      value: Course.active.count,   icon: "book" },
        { label: "Aulas concluídas",   value: completed_count,        icon: "check" },
        { label: "Total de aulas",     value: total_lessons,          icon: "film" },
        { label: "Progresso geral",    value: "#{pct_overall}%",      icon: "ring", pct: pct_overall }
      ].each do |stat| %>
        <div class="bg-white rounded-2xl border border-gray-100 p-4 flex items-center gap-3">
          <% if stat[:icon] == "ring" %>
            <%= render "shared/merma/progress_ring", pct: stat[:pct], size: 40, stroke_width: 4 %>
          <% else %>
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: var(--color-primary-10); color: var(--color-primary);">
              <% case stat[:icon] %>
              <% when "book" %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              <% when "check" %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              <% when "film" %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              <% end %>
            </div>
          <% end %>
          <div>
            <p class="text-lg font-bold text-gray-900 leading-none"><%= stat[:value] %></p>
            <p class="text-xs text-gray-400 mt-0.5"><%= stat[:label] %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Cursos em destaque %>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-900">Cursos disponíveis</h2>
    <%= link_to courses_path, class: "text-xs font-medium hover:underline", style: "color: var(--color-primary);" do %>
      Ver todos →
    <% end %>
  </div>

  <% if @featured_courses.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
      <% @featured_courses.each_with_index do |course, i| %>
        <% color = merma_course_color(i) %>
        <%= link_to course_path(course), class: "group bg-white rounded-2xl border border-gray-100 p-4 hover:shadow-md transition-shadow flex flex-col gap-3" do %>
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold flex-shrink-0"
                  style="background: <%= color[:bg] %>; color: <%= color[:text] %>;">
              <%= course.name.first.upcase %>
            </span>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate group-hover:text-[var(--color-primary)] transition-colors">
                <%= course.name %>
              </p>
              <p class="text-xs text-gray-400">
                <%= pluralize(course.sessions.count, "módulo", "módulos") %> ·
                <%= pluralize(course.sessions.sum { |s| s.lessons.count }, "aula", "aulas") %>
              </p>
            </div>
          </div>
          <% if course.description.present? %>
            <p class="text-xs text-gray-400 line-clamp-2 leading-relaxed"><%= course.description %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 rounded-2xl border-2 border-dashed border-gray-200">
      <svg class="w-8 h-8 text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      <p class="text-sm text-gray-400">Nenhum curso disponível ainda</p>
    </div>
  <% end %>

  <%# CTA visitantes %>
  <% unless user_signed_in? %>
    <div class="mt-8 rounded-2xl p-6 text-center border border-gray-100 bg-gray-50">
      <p class="text-sm font-semibold text-gray-800 mb-1">Crie sua conta gratuita</p>
      <p class="text-xs text-gray-400 mb-4">Acesse todos os cursos e acompanhe seu progresso.</p>
      <div class="flex justify-center gap-3">
        <%= link_to "Criar conta", new_user_registration_path,
              class: "merma-btn-primary px-5 py-2 text-sm rounded-xl" %>
        <%= link_to "Entrar", new_user_session_path,
              class: "px-5 py-2 text-sm rounded-xl border border-gray-200 text-gray-700 hover:bg-white transition-colors" %>
      </div>
    </div>
  <% end %>

</div>
