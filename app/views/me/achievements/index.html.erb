<% content_for :title, "Minhas conquistas" %>
<% if themed_layout? %>
  <% content_for :header_title, "Conquistas" %>
<% end %>

<%= render "shared/header" unless themed_layout? %>

<div class="<%= themed_layout? ? 'max-w-4xl mx-auto px-5 py-6' : 'container mx-auto px-4 py-8 max-w-4xl' %>">
  <% streak = student_streak_display %>
  <% if streak.to_i.positive? %>
    <div class="mb-6 rounded-xl border border-orange-200 bg-orange-50 px-4 py-3 flex items-center gap-3">
      <span class="text-2xl" aria-hidden="true">🔥</span>
      <div>
        <p class="text-sm font-semibold text-gray-900">Sequência de estudo</p>
        <p class="text-sm text-gray-600"><%= streak %> <%= streak == 1 ? "dia" : "dias" %> seguidos estudando</p>
      </div>
    </div>
  <% end %>

  <p class="text-sm text-gray-600 mb-6">
    Complete aulas e provas para desbloquear conquistas.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @achievements.each do |achievement| %>
      <% earned = @earned_ids.include?(achievement.id) %>
      <% ua = @earned[achievement.id] %>
      <div class="rounded-xl border p-4 text-center <%= earned ? 'border-primary/30 bg-white shadow-sm' : 'border-gray-200 bg-gray-50 opacity-80' %>">
        <div class="mb-3 <%= 'grayscale' unless earned %>">
          <%= achievement_badge_image(achievement, css_class: "w-20 h-20 object-contain mx-auto") %>
        </div>
        <h2 class="font-semibold text-gray-900 text-sm"><%= achievement.name %></h2>
        <p class="text-xs text-gray-500 mt-1"><%= achievement.description %></p>
        <% if earned && ua %>
          <p class="text-xs text-primary font-medium mt-2">
            Conquistada em <%= l(ua.awarded_at, format: :short) %>
          </p>
        <% else %>
          <p class="text-xs text-gray-400 mt-2">Ainda não conquistada</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
