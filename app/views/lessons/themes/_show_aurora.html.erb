<%# Aula – layout Aurora (split: conteúdo + playlist) %>
<% content_for :header_title, @lesson.name %>
<% content_for :header_subtitle, "#{@course.name} · #{@session.name}" %>
<% content_for :main_class, "overflow-hidden flex flex-col" %>

<% content_for :header_actions do %>
  <button type="button"
          class="xl:hidden px-2.5 py-1.5 text-xs font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors flex-shrink-0"
          data-drawer-toggle="aurora-lesson-playlist"
          data-drawer-backdrop="aurora-playlist-backdrop"
          aria-expanded="false"
          aria-label="Lista de aulas">
    Aulas
  </button>
<% end %>

<div class="flex flex-1 overflow-hidden min-w-0">

  <%# ── Coluna principal ── %>
  <div class="flex-1 overflow-y-auto min-w-0">

    <%# Player %>
    <%= render "lessons/themes/aurora/video_player" %>

    <%# Tabs: Descrição | Quiz | Feedback %>
    <%= render "lessons/themes/aurora/content_tabs" %>

  </div>

  <div id="aurora-playlist-backdrop"
       class="fixed inset-0 bg-black/40 z-30 xl:hidden hidden"
       aria-hidden="true"></div>

  <%# ── Playlist lateral (drawer &lt; xl) ── %>
  <%= render "shared/aurora/lesson_playlist",
        course: @course,
        sessions: @sessions,
        all_lessons: @all_lessons,
        completions: @completions,
        current_lesson: @lesson %>

</div>
