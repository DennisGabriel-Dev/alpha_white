<%# Sub-partial: seção de quiz dentro da aba (Aurora) %>

<% quiz_comp = @lesson.lesson_completions.find_by(user: current_user) %>

<% if @lesson.quiz.present? %>

  <div class="flex items-start justify-between gap-4 mb-5">
    <div>
      <h3 class="text-sm font-semibold text-gray-900"><%= @lesson.quiz.title %></h3>
      <p class="text-xs text-gray-400 mt-0.5"><%= pluralize(@lesson.quiz.questions.count, "questão", "questões") %></p>
    </div>
    <% if quiz_comp&.quiz_completed? %>
      <span class="inline-flex items-center gap-1.5 text-xs font-medium text-green-600 bg-green-50 px-3 py-1.5 rounded-lg flex-shrink-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
        Concluída
      </span>
    <% end %>
  </div>

  <% unless quiz_comp&.quiz_completed? %>
    <% if @lesson.quiz.questions.any? %>
      <%= link_to take_course_session_lesson_quiz_path(@course, @session, @lesson),
            class: "aurora-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold mb-4" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Iniciar prova
      <% end %>

      <div class="border-t border-gray-100 pt-4">
        <%= form_with url: course_session_lesson_lesson_completion_path(@course, @session, @lesson),
              method: :patch, local: true do %>
          <input type="hidden" name="lesson_completion[quiz_completed]" value="true">
          <button type="submit"
                  class="text-xs text-gray-400 hover:text-[var(--color-primary)] font-medium transition-colors">
            Marcar como concluída sem refazer
          </button>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">Esta prova ainda não tem questões cadastradas.</p>
    <% end %>
  <% end %>

  <% if admin_or_instructor? %>
    <div class="mt-6 pt-4 border-t border-gray-100">
      <%= link_to course_session_lesson_quiz_questions_path(@course, @session, @lesson),
            class: "inline-flex items-center gap-1.5 text-xs font-medium text-gray-400 hover:text-[var(--color-primary)] transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Gerenciar questões
      <% end %>
    </div>
  <% end %>

<% elsif admin_or_instructor? %>

  <div class="flex flex-col items-center justify-center py-10 text-center rounded-xl border-2 border-dashed border-gray-200">
    <svg class="w-8 h-8 text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    <p class="text-sm text-gray-400 mb-3">Esta aula ainda não tem prova.</p>
    <%= link_to new_course_session_lesson_quiz_path(@course, @session, @lesson),
          class: "aurora-btn-primary px-4 py-2 rounded-xl text-xs font-semibold" do %>
      Criar prova
    <% end %>
  </div>

<% else %>
  <p class="text-sm text-gray-400">Esta aula não possui prova.</p>
<% end %>
