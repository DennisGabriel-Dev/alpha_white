<%# Sub-partial: player de vídeo – Merma %>

<div class="flex-shrink-0 bg-gray-900"
     style="<%= @lesson.video.attached? || @lesson.video_url.present? ? '' : 'background: var(--color-primary-10);' %>">

  <% if @lesson.video.attached? %>
    <div style="aspect-ratio: 16/9; max-height: 52vh;">
      <%= video_tag url_for(@lesson.video),
            controls: true, preload: "metadata",
            class: "w-full h-full object-contain bg-black block" %>
    </div>
  <% elsif @lesson.video_url.present? %>
    <div style="aspect-ratio: 16/9; max-height: 52vh;">
      <iframe src="<%= @lesson.video_url %>"
              class="w-full h-full block"
              allowfullscreen></iframe>
    </div>
  <% else %>
    <div class="flex items-center justify-center bg-gray-100"
         style="aspect-ratio: 16/9; max-height: 52vh;">
      <div class="text-center text-gray-400">
        <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
        </svg>
        <p class="text-sm">Nenhum vídeo nesta aula</p>
      </div>
    </div>
  <% end %>

</div>

<%# Barra inferior do player %>
<% if @lesson.video.attached? || @lesson.video_url.present? %>
  <% comp = @lesson.lesson_completions.find_by(user: current_user) %>
  <div class="flex items-center justify-between px-5 py-2.5 border-b border-gray-100 bg-white flex-shrink-0">
    <div class="flex items-center gap-2 text-xs text-gray-400">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <span>Aula</span>
      <span class="text-gray-300">·</span>
      <span class="font-medium text-gray-600"><%= @lesson.name %></span>
    </div>

    <% if comp&.video_watched? %>
      <span class="inline-flex items-center gap-1 text-xs font-medium text-green-600">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
        Assistido
      </span>
    <% else %>
      <%= form_with url: course_session_lesson_lesson_completion_path(@course, @session, @lesson),
            method: :patch, local: true do %>
        <input type="hidden" name="lesson_completion[video_watched]" value="true">
        <button type="submit"
                class="inline-flex items-center gap-1 text-xs font-medium transition-colors"
                style="color: var(--color-primary);">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          Marcar como assistido
        </button>
      <% end %>
    <% end %>
  </div>
<% end %>
