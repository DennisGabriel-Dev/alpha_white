<%# Sub-partial: tabs de conteúdo da aula – Merma
    Tabs: Resumo | Descrição | Prova | Feedback %>

<div class="flex flex-col flex-1 overflow-hidden" id="merma-lesson-tabs">

  <%# Tab bar %>
  <div class="flex items-center gap-0 border-b border-gray-100 px-5 flex-shrink-0 bg-white overflow-x-auto" id="merma-tab-bar">
    <% tabs = [{ id: "summary", label: "Resumo" }] %>
    <% tabs << { id: "description", label: "Descrição" } if @lesson.description.present? %>
    <% tabs << { id: "quiz",        label: "Prova"     } if @lesson.quiz.present? || admin_or_instructor? %>
    <% tabs << { id: "feedback",    label: "Feedback"  } %>

    <% tabs.each_with_index do |tab, i| %>
      <button type="button"
              class="merma-tab-btn px-4 py-3 text-sm font-medium border-b-2 -mb-px transition-colors
                     <%= i == 0 ? 'border-[var(--color-primary)] text-[var(--color-primary)]'
                                : 'border-transparent text-gray-400 hover:text-gray-700' %>"
              data-tab="<%= tab[:id] %>">
        <%= tab[:label] %>
      </button>
    <% end %>
  </div>

  <%# Painéis %>
  <div class="flex-1 overflow-y-auto">

    <%# ── Resumo ── %>
    <div id="merma-tab-summary" class="merma-tab-panel p-5">
      <div class="max-w-2xl">
        <h2 class="text-base font-semibold text-gray-900 mb-1"><%= @lesson.name %></h2>
        <p class="text-xs text-gray-400 mb-4"><%= @course.name %> · <%= @session.name %></p>

        <% if @lesson.description.present? %>
          <div class="bg-gray-50 rounded-xl p-4 mb-4">
            <p class="text-sm font-medium text-gray-700 mb-2">Sobre esta aula</p>
            <p class="text-sm text-gray-500 leading-relaxed line-clamp-3"><%= @lesson.description %></p>
          </div>
        <% end %>

        <%# Quick status cards %>
        <div class="grid grid-cols-2 gap-3">
          <% comp = @lesson.lesson_completions.find_by(user: current_user) %>

          <div class="rounded-xl border border-gray-100 p-3 flex items-center gap-2.5">
            <span class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0
                         <%= comp&.video_watched? ? 'bg-green-50' : 'bg-gray-100' %>">
              <svg class="w-4 h-4 <%= comp&.video_watched? ? 'text-green-500' : 'text-gray-400' %>"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-medium text-gray-700">Vídeo</p>
              <p class="text-[11px] <%= comp&.video_watched? ? 'text-green-500' : 'text-gray-400' %>">
                <%= comp&.video_watched? ? "Assistido" : "Não assistido" %>
              </p>
            </div>
          </div>

          <div class="rounded-xl border border-gray-100 p-3 flex items-center gap-2.5">
            <span class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0
                         <%= comp&.quiz_completed? ? 'bg-green-50' : 'bg-gray-100' %>">
              <svg class="w-4 h-4 <%= comp&.quiz_completed? ? 'text-green-500' : 'text-gray-400' %>"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </span>
            <div>
              <p class="text-xs font-medium text-gray-700">Prova</p>
              <p class="text-[11px] <%= comp&.quiz_completed? ? 'text-green-500' : 'text-gray-400' %>">
                <%= comp&.quiz_completed? ? "Concluída" : (@lesson.quiz.present? ? "Pendente" : "Sem prova") %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Descrição ── %>
    <div id="merma-tab-description" class="merma-tab-panel hidden p-5">
      <div class="max-w-2xl">
        <% if @lesson.description.present? %>
          <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-wrap"><%= @lesson.description %></p>
        <% else %>
          <p class="text-sm text-gray-400">Esta aula não possui descrição.</p>
        <% end %>
      </div>
    </div>

    <%# ── Prova ── %>
    <div id="merma-tab-quiz" class="merma-tab-panel hidden p-5">
      <div class="max-w-2xl">
        <% quiz_comp = @lesson.lesson_completions.find_by(user: current_user) %>
        <% if @lesson.quiz.present? %>
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-sm font-semibold text-gray-900"><%= @lesson.quiz.title %></h3>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= pluralize(@lesson.quiz.questions.count, "questão", "questões") %>
              </p>
            </div>
            <% if quiz_comp&.quiz_completed? %>
              <span class="inline-flex items-center gap-1.5 text-xs font-medium text-green-600 bg-green-50 px-3 py-1.5 rounded-lg">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                Concluída
              </span>
            <% end %>
          </div>

          <% unless quiz_comp&.quiz_completed? %>
            <% if @lesson.quiz.questions.any? %>
              <% quiz_unlocked = admin_or_instructor? || @lesson.video_prerequisite_met_for?(current_user) %>
              <% if quiz_unlocked %>
                <%= link_to take_course_session_lesson_quiz_path(@course, @session, @lesson),
                      class: "merma-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                  Iniciar prova
                <% end %>
              <% else %>
                <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
                  Assista à aula antes de iniciar a prova.
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-gray-400">A prova ainda não possui questões.</p>
            <% end %>
          <% end %>

          <% if @lesson.quiz.user_has_student_answers?(current_user) %>
            <div class="mt-4">
              <%= link_to review_course_session_lesson_quiz_path(@course, @session, @lesson),
                    class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border-2 transition-colors",
                    style: "border-color: var(--color-primary); color: var(--color-primary);" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                Conferir respostas
              <% end %>
            </div>
          <% end %>

          <% if admin_or_instructor? %>
            <div class="mt-4 pt-4 border-t border-gray-100">
              <%= link_to course_session_lesson_quiz_questions_path(@course, @session, @lesson),
                    class: "text-xs font-medium hover:underline transition-colors",
                    style: "color: var(--color-primary);" do %>
                Gerenciar questões →
              <% end %>
            </div>
          <% end %>
        <% elsif admin_or_instructor? %>
          <div class="flex flex-col items-center py-10 rounded-2xl border-2 border-dashed border-gray-200 text-center">
            <svg class="w-8 h-8 text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <p class="text-sm text-gray-400 mb-3">Esta aula não tem prova.</p>
            <%= link_to new_course_session_lesson_quiz_path(@course, @session, @lesson),
                  class: "merma-btn-primary px-4 py-2 rounded-xl text-xs font-semibold" do %>
              Criar prova
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400">Esta aula não possui prova.</p>
        <% end %>
      </div>
    </div>

    <%# ── Feedback ── %>
    <div id="merma-tab-feedback" class="merma-tab-panel hidden p-5">
      <div class="max-w-2xl">
        <% if @my_feedback %>
          <div class="rounded-2xl border border-green-200 bg-green-50 p-4 mb-5">
            <div class="flex items-center justify-between mb-1">
              <p class="text-sm font-semibold text-green-800">Seu feedback</p>
              <span class="text-yellow-500 text-sm">
                <%= "★" * @my_feedback.rating %><%= "☆" * (5 - @my_feedback.rating) %>
              </span>
            </div>
            <% if @my_feedback.description.present? %>
              <p class="text-sm text-green-700"><%= @my_feedback.description %></p>
            <% end %>
          </div>
        <% else %>
          <h3 class="text-sm font-semibold text-gray-900 mb-4">Avalie esta aula</h3>
          <%= form_with url: course_session_lesson_feedbacks_path(@course, @session, @lesson),
                method: :post, local: true, class: "space-y-4 mb-6" do %>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-2">Sua nota</label>
              <div class="flex gap-1">
                <% (1..5).each do |i| %>
                  <label class="cursor-pointer">
                    <input type="radio" name="feedback[rating]" value="<%= i %>" class="sr-only peer" required>
                    <svg class="w-7 h-7 text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 transition-colors"
                         fill="currentColor" viewBox="0 0 24 24">
                      <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                    </svg>
                  </label>
                <% end %>
              </div>
            </div>
            <textarea name="feedback[description]" rows="3"
                      class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl bg-gray-50
                             focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/20 resize-none"
                      placeholder="Deixe um comentário (opcional)..."></textarea>
            <button type="submit" class="merma-btn-primary px-5 py-2 rounded-xl text-sm font-semibold">
              Enviar feedback
            </button>
          <% end %>
        <% end %>

        <% if @feedbacks.any? %>
          <div class="border-t border-gray-100 pt-5">
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">
              Outros feedbacks (<%= @feedbacks.count %>)
            </h4>
            <div class="space-y-3">
              <% @feedbacks.each do |fb| %>
                <div class="rounded-xl border border-gray-100 bg-gray-50 p-3.5">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs font-medium text-gray-700">
                      <%= fb.user.email.split("@").first %>
                    </span>
                    <span class="text-yellow-400 text-xs">
                      <%= "★" * fb.rating %><%= "☆" * (5 - fb.rating) %>
                    </span>
                  </div>
                  <% if fb.description.present? %>
                    <p class="text-xs text-gray-500 leading-relaxed"><%= fb.description %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('turbo:load', function () {
    const bar = document.getElementById('merma-tab-bar');
    if (!bar) return;

    function activate(id) {
      bar.querySelectorAll('.merma-tab-btn').forEach(function (btn) {
        const on = btn.dataset.tab === id;
        btn.classList.toggle('border-[var(--color-primary)]', on);
        btn.classList.toggle('text-[var(--color-primary)]', on);
        btn.classList.toggle('border-transparent', !on);
        btn.classList.toggle('text-gray-400', !on);
      });
      document.querySelectorAll('.merma-tab-panel').forEach(function (p) {
        p.classList.toggle('hidden', p.id !== 'merma-tab-' + id);
      });
    }

    bar.querySelectorAll('.merma-tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { activate(btn.dataset.tab); });
    });

    <% if params[:tab].present? %>
      activate('<%= params[:tab] %>');
    <% end %>
  });
</script>
