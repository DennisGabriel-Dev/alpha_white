<%# locals: f (form builder) %>
<div>
  <%= f.label :quiz_time_limit_minutes, "Tempo limite da prova (minutos)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
  <%= f.number_field :quiz_time_limit_minutes,
        class: "w-full sm:w-32 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-sm",
        min: 1,
        value: f.object.quiz_time_limit_minutes.presence || (Lesson::DEFAULT_QUIZ_TIME_LIMIT_SECONDS / 60).round %>
  <p class="mt-1 text-xs text-gray-500">Padrão: 10 min. O aluno só envia a prova dentro deste tempo.</p>
</div>
