<%# Página da aula: vídeo, descrição, feedback do estudante %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <nav class="mb-6">
    <%= link_to course_session_path(@course, @session), class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
      <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
      Voltar para <%= @session.name %>
    <% end %>
  </nav>

  <% if notice %>
    <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-lg text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <div class="card mb-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
      <h1 class="text-2xl font-bold text-gray-800"><%= @lesson.name %></h1>
      <% completion = @lesson.lesson_completions.find_by(user: current_user) %>
      <% if completion && (completion.lesson.quiz.blank? || completion.quiz_completed?) && ((!completion.lesson.video.attached? && completion.lesson.video_url.blank?) || completion.video_watched?) %>
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800">
          <%= heroicon(:check_circle, variant: :solid, css_class: "w-5 h-5") %>
          Aula concluída
        </span>
      <% end %>
    </div>

    <% if @lesson.video.attached? || @lesson.video_url.present? %>
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Vídeo</h2>
        <% if @lesson.video.attached? %>
          <div class="rounded-lg overflow-hidden bg-black">
            <%= video_tag url_for(@lesson.video), controls: true, preload: "metadata", class: "w-full aspect-video" %>
          </div>
          <% if @lesson.video_url.present? && admin_or_instructor? %>
            <p class="text-xs text-gray-500 mt-2">
              Observação: há também uma `video_url` cadastrada, mas o upload tem prioridade na exibição.
            </p>
          <% end %>
        <% else %>
          <div class="aspect-video rounded-lg overflow-hidden bg-gray-900">
            <iframe src="<%= @lesson.video_url %>" class="w-full h-full" allowfullscreen></iframe>
          </div>
        <% end %>
        <% video_completion = @lesson.lesson_completions.find_by(user: current_user) %>
        <% if video_completion&.video_watched? %>
          <p class="text-sm text-green-600 mt-2"><%= heroicon(:check_circle, css_class: "w-4 h-4 inline") %> Vídeo assistido</p>
        <% else %>
          <%= form_with url: course_session_lesson_lesson_completion_path(@course, @session, @lesson), method: :patch, local: true, class: "mt-2" do %>
            <input type="hidden" name="lesson_completion[video_watched]" value="true">
            <button type="submit" class="text-sm text-primary font-medium hover:underline">Marcar vídeo como assistido</button>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if @lesson.quiz.present? %>
      <div class="mb-6 p-4 bg-gray-50 rounded-lg">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-2">
          <h2 class="text-lg font-semibold text-gray-700">Prova: <%= @lesson.quiz.title %></h2>
          <% if admin_or_instructor? %>
            <%= link_to course_session_lesson_quiz_questions_path(@course, @session, @lesson), class: "text-sm text-primary font-medium hover:underline" do %>
              Gerenciar questões
              <%= heroicon(:pencil, css_class: "w-4 h-4 inline") %>
            <% end %>
          <% end %>
        </div>
        <% quiz_completion = @lesson.lesson_completions.find_by(user: current_user) %>
        <% if quiz_completion&.quiz_completed? %>
          <p class="text-sm text-green-600"><%= heroicon(:check_circle, css_class: "w-4 h-4 inline") %> Prova concluída</p>
        <% else %>
          <% if student? %>
            <p class="text-gray-600 mb-2">Responda as questões abaixo e depois marque a prova como concluída.</p>
            <%= link_to take_course_session_lesson_quiz_path(@course, @session, @lesson), class: "btn-primary inline-flex items-center text-sm py-2 px-4" do %>
              Fazer prova
              <%= heroicon(:chart_bar, css_class: "w-4 h-4 ml-2") %>
            <% end %>
            <div class="mt-4 pt-4 border-t border-gray-200">
              <%= form_with url: course_session_lesson_lesson_completion_path(@course, @session, @lesson), method: :patch, local: true do %>
                <input type="hidden" name="lesson_completion[quiz_completed]" value="true">
                <button type="submit" class="text-sm text-primary font-medium hover:underline">Marcar prova como concluída</button>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% elsif admin_or_instructor? %>
      <div class="mb-6 p-4 bg-gray-100 rounded-lg border border-dashed border-gray-300">
        <p class="text-gray-600 mb-2">Esta aula ainda não possui prova.</p>
        <%= link_to new_course_session_lesson_quiz_path(@course, @session, @lesson), class: "text-sm text-primary font-medium hover:underline inline-flex items-center" do %>
          <%= heroicon(:plus, css_class: "w-4 h-4 mr-1") %>
          Adicionar prova
        <% end %>
      </div>
    <% end %>

    <% if @lesson.description.present? %>
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Descrição</h2>
        <p class="text-gray-600 leading-relaxed whitespace-pre-wrap"><%= @lesson.description %></p>
      </div>
    <% end %>

    <% if admin_or_instructor? %>
      <div class="pt-4 border-t border-gray-200">
        <%= link_to edit_course_session_lesson_path(@course, @session, @lesson), class: "text-primary font-medium hover:underline" do %>
          <%= heroicon(:pencil, css_class: "w-4 h-4 inline-block mr-1") %>
          Editar aula
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Feedback do estudante %>
  <div class="card">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Seu feedback</h2>
    <% if @my_feedback %>
      <div class="p-4 bg-green-50 rounded-lg border border-green-200">
        <%= render "feedback/feedback_component", feedback: @my_feedback %>
        <p class="text-sm text-gray-500 mt-2">Obrigado pelo feedback!</p>
      </div>
    <% else %>
      <%= form_with url: course_session_lesson_feedbacks_path(@course, @session, @lesson), method: :post, local: true, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Avalie esta aula (1 a 5 estrelas)</label>
          <div class="flex gap-2" id="rating-stars">
            <% (1..5).each do |i| %>
              <label class="cursor-pointer">
                <input type="radio" name="feedback[rating]" value="<%= i %>" class="sr-only peer" required>
                <span class="text-2xl text-gray-300 peer-checked:text-yellow-500 hover:text-yellow-400">★</span>
              </label>
            <% end %>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Comentário (opcional)</label>
          <textarea name="feedback[description]" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Pontos positivos ou negativos..."></textarea>
        </div>
        <div>
          <button type="submit" class="btn-primary cursor-pointer">Enviar feedback</button>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="card">
    <h2 class="text-xl font-bold text-gray-800 mb-4">Demais feedbacks</h2>
    <% @feedbacks.each do |feedback|%>
      <%= render "feedback/feedback_component", feedback: feedback %>
    <% end %>
  </div>
</div>

<%= render "shared/footer" %>
