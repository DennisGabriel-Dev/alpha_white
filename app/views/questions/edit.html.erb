<%# Editar questão com alternativas dinâmicas %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8 max-w-2xl">
  <nav class="mb-6">
    <%= link_to course_session_lesson_quiz_questions_path(@course, @session, @lesson), class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
      <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
      Voltar para questões
    <% end %>
  </nav>

  <div class="card">
    <h1 class="text-xl font-bold text-gray-800 mb-6">Editar questão</h1>
    <%= render "form", question: @question %>
  </div>
</div>

<%= render "shared/footer" %>
