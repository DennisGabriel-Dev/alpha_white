<%# Lista de questões da prova %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <nav class="mb-6">
    <%= link_to course_session_lesson_path(@course, @session, @lesson), class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
      <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
      Voltar para <%= @lesson.name %>
    <% end %>
  </nav>

  <% if notice %>
    <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-lg text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <div class="card mb-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Prova: <%= @quiz.title %></h1>
        <p class="text-gray-500 text-sm mt-1"><%= @lesson.name %></p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to edit_course_session_lesson_quiz_path(@course, @session, @lesson), class: "px-4 py-2 text-sm font-medium text-primary border border-primary rounded-lg hover:bg-primary/5 transition-colors" do %>
          <%= heroicon(:pencil, css_class: "w-4 h-4 inline-block mr-1") %>
          Editar prova
        <% end %>
        <%= button_to course_session_lesson_quiz_path(@course, @session, @lesson), method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover esta prova e todas as questões?" }, class: "px-4 py-2 text-sm font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors" do %>
          <%= heroicon(:trash, css_class: "w-4 h-4 inline-block mr-1") %>
          Remover prova
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h2 class="text-xl font-bold text-gray-800">
      Questões
      <% if @questions.any? %>
        <span class="text-gray-500 font-normal text-base ml-2">(<%= @questions.count %>)</span>
      <% end %>
    </h2>
    <div class="flex flex-wrap gap-2">
      <%= link_to new_course_session_lesson_quiz_enem_import_path(@course, @session, @lesson), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-emerald-700 rounded-lg hover:bg-emerald-800 transition-colors" do %>
        <%= heroicon(:book_open, css_class: "w-5 h-5 mr-2") %>
        Biblioteca ENEM
      <% end %>
      <%= link_to new_course_session_lesson_quiz_question_path(@course, @session, @lesson), class: "btn-primary inline-flex items-center" do %>
        <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
        Nova questão
      <% end %>
    </div>
  </div>

  <% if @questions.any? %>
    <div class="space-y-6">
      <% @questions.each_with_index do |question, index| %>
        <div class="card">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
            <div class="flex-1">
              <h3 class="font-semibold text-gray-800 mb-2 flex flex-wrap items-center gap-2">
                <span><%= index + 1 %>. <%= question.enunciation %></span>
                <% if question.from_enem? %>
                  <span class="text-xs font-normal px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800">ENEM</span>
                <% end %>
              </h3>
              <% if question.question_options.any? %>
                <ul class="list-disc list-inside text-sm text-gray-600 space-y-1 ml-4">
                  <% question.question_options.each do |opt| %>
                    <li>
                      <%= opt.text %>
                      <% if opt.correct? %>
                        <span class="text-green-600 font-medium">(correta)</span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to edit_course_session_lesson_quiz_question_path(@course, @session, @lesson, question), class: "px-4 py-2 text-sm font-medium text-primary border border-primary rounded-lg hover:bg-primary/5 transition-colors" do %>
                <%= heroicon(:pencil, css_class: "w-4 h-4 inline-block mr-1") %>
                Editar
              <% end %>
              <%= button_to course_session_lesson_quiz_question_path(@course, @session, @lesson, question), method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover esta questão?" }, class: "px-4 py-2 text-sm font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors" do %>
                <%= heroicon(:trash, css_class: "w-4 h-4 inline-block mr-1") %>
                Remover
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <span class="text-5xl mb-4 inline-block">📝</span>
      <h3 class="text-lg font-semibold text-gray-700 mb-2">Nenhuma questão cadastrada</h3>
      <p class="text-gray-500 mb-4">Adicione a primeira questão para esta prova.</p>
      <%= link_to new_course_session_lesson_quiz_question_path(@course, @session, @lesson), class: "btn-primary inline-flex items-center" do %>
        <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
        Nova questão
      <% end %>
    </div>
  <% end %>
</div>

<%= render "shared/footer" %>
