<%# Quiz take / review – Merma %>
<% review_mode = @quiz_review.present? %>
<% questions = @quiz.questions.includes(:question_options, student_answers: :question_option) %>
<% uid = current_user.id %>

<%# ── Breadcrumb ── %>
<% content_for :breadcrumb do %>
  <nav class="flex items-center gap-1.5 text-sm text-gray-400 overflow-hidden">
    <%= link_to "Cursos", courses_path, class: "hover:text-gray-700 transition-colors flex-shrink-0" %>
    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <%= link_to @course.name, course_path(@course),
          class: "hover:text-gray-700 transition-colors truncate max-w-[8rem] flex-shrink-0" %>
    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <%= link_to @lesson.name, course_session_lesson_path(@course, @session, @lesson),
          class: "hover:text-gray-700 transition-colors truncate max-w-[8rem] flex-shrink-0" %>
    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-800 font-medium truncate">
      <%= @quiz.title %><%= " · Conferência" if review_mode %>
    </span>
  </nav>
<% end %>

<%# ── Ações ── %>
<% quiz_label = "quiz-progress-label" %>
<% content_for :header_actions do %>
  <% if review_mode %>
    <span class="text-xs font-medium text-gray-700" id="<%= quiz_label %>">
      <%= @review_correct %>/<%= @review_total %> acertos
    </span>
  <% else %>
    <span class="text-xs text-gray-400" id="<%= quiz_label %>">
      0 de <%= questions.count %> respondidas
    </span>
  <% end %>
<% end %>

<div class="h-full overflow-y-auto">

  <%# Barra de progresso linear %>
  <div class="h-1 bg-gray-100 flex-shrink-0">
    <div id="merma-quiz-bar" class="h-full transition-all duration-300 rounded-r-full"
         style="width: <%= review_mode && @review_total.to_i.positive? ? ((@review_correct.to_f / @review_total) * 100).round(1) : 0 %>%; background: var(--color-primary);"></div>
  </div>

  <div class="max-w-2xl mx-auto px-4 sm:px-5 py-6">

    <%# Cabeçalho %>
    <div class="mb-6">
      <h1 class="text-lg font-bold text-gray-900"><%= @quiz.title %></h1>
      <p class="text-sm text-gray-400 mt-1">
        <%= @lesson.name %> · <%= pluralize(questions.count, "questão", "questões") %>
      </p>
      <% if review_mode && @review_total.to_i.positive? %>
        <p class="text-sm text-gray-600 mt-2">
          Você acertou <strong><%= @review_correct %></strong> de <strong><%= @review_total %></strong>
          (<%= number_to_percentage((@review_correct.to_f / @review_total) * 100, precision: 0) %>).
          Alternativas em <span class="text-green-700 font-medium">verde</span> são o gabarito;
          em <span class="text-red-700 font-medium">vermelho</span>, sua escolha quando errou.
        </p>
      <% end %>
    </div>

    <% if review_mode %>
      <div class="space-y-5">
        <% questions.each_with_index do |question, index| %>
          <% my_answer = @review_attempt&.student_answers&.find { |a| a.question_id == question.id } %>
          <% picked = my_answer&.question_option %>
          <% status =
               if picked.nil?
                 :blank
               elsif picked.correct?
                 :ok
               else
                 :wrong
               end %>
          <div class="bg-white rounded-2xl border border-gray-100 p-5 merma-question"
               id="q-<%= question.id %>">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold"
                    style="background: var(--color-primary-10); color: var(--color-primary);">
                <%= index + 1 %>
              </span>
              <% if status == :ok %>
                <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded-lg">Acertou</span>
              <% elsif status == :wrong %>
                <span class="text-xs font-semibold text-red-700 bg-red-50 px-2 py-0.5 rounded-lg">Errou</span>
              <% else %>
                <span class="text-xs font-semibold text-gray-600 bg-gray-100 px-2 py-0.5 rounded-lg">Sem resposta</span>
              <% end %>
            </div>
            <p class="text-sm font-medium text-gray-800 leading-relaxed mb-4">
              <%= question.enunciation %>
            </p>

            <div class="space-y-2 pl-0 sm:pl-2">
              <% question.question_options.each do |option| %>
                <% correct = option.correct? %>
                <% chosen = picked&.id == option.id %>
                <% row_class =
                     if correct
                       "border-green-300 bg-green-50"
                     elsif chosen && !correct
                       "border-red-300 bg-red-50"
                     else
                       "border-gray-100 bg-gray-50/80"
                     end %>
                <div class="flex flex-wrap items-start gap-2 sm:gap-3 p-3 rounded-xl border <%= row_class %>">
                  <span class="text-sm text-gray-800 flex-1 min-w-0"><%= option.text %></span>
                  <% if correct %>
                    <span class="text-[10px] font-semibold uppercase text-green-700 flex-shrink-0">Gabarito</span>
                  <% elsif chosen %>
                    <span class="text-[10px] font-semibold uppercase text-red-700 flex-shrink-0">Sua resposta</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 mt-6 pt-4 border-t border-gray-100">
        <%= link_to course_session_lesson_path(@course, @session, @lesson, tab: "quiz"),
              class: "merma-btn-primary inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Voltar à aula
        <% end %>
      </div>
    <% else %>
      <% timed_quiz = @quiz_attempt.present? && @expires_at.present? %>
      <div <%= timed_quiz ? "data-controller=\"quiz-timer\" data-quiz-timer-expires-at-value=\"#{@expires_at.iso8601}\"".html_safe : "" %>>
        <%= render "quizzes/timer" if timed_quiz %>
      <%= form_with url: submit_course_session_lesson_quiz_path(@course, @session, @lesson),
            method: :post, local: true, id: "merma-quiz-form",
            data: (timed_quiz ? { quiz_timer_target: "form" } : {}) do %>

        <div class="space-y-5">
          <% questions.each_with_index do |question, index| %>
            <% my_answer = @quiz_attempt&.student_answers&.find { |a| a.question_id == question.id } %>
            <% question_id = question.id %>
            <div class="bg-white rounded-2xl border border-gray-100 p-5 merma-question"
                 id="q-<%= question_id %>"
                 data-question-id="<%= question_id %>">
              <div class="flex gap-3 mb-4">
                <span class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold mt-0.5"
                      style="background: var(--color-primary-10); color: var(--color-primary);">
                  <%= index + 1 %>
                </span>
                <p class="text-sm font-medium text-gray-800 leading-relaxed">
                  <%= question.enunciation %>
                </p>
              </div>

              <div class="space-y-2 pl-0 sm:pl-9">
                <% question.question_options.each do |option| %>
                  <% checked = my_answer&.question_option_id == option.id %>
                  <label class="merma-option flex items-center gap-3 p-3 rounded-xl border cursor-pointer
                                transition-all select-none
                                <%= checked ? 'border-[var(--color-primary)] bg-[var(--color-primary)]/5'
                                            : 'border-gray-200 hover:border-gray-300 hover:bg-gray-50' %>"
                         data-question="<%= question.id %>">
                    <span class="w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-colors
                                 <%= checked ? 'border-[var(--color-primary)]' : 'border-gray-300' %>">
                      <span class="w-2 h-2 rounded-full bg-[var(--color-primary)] transition-all
                                   <%= checked ? 'scale-100 opacity-100' : 'scale-0 opacity-0' %>
                                   option-dot"></span>
                    </span>
                    <input type="radio" name="answers[<%= question.id %>]" value="<%= option.id %>"
                           class="sr-only merma-radio" <%= "checked" if checked %>>
                    <span class="text-sm text-gray-700"><%= option.text %></span>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 mt-6 pt-4 border-t border-gray-100">
          <%= link_to course_session_lesson_path(@course, @session, @lesson),
                class: "inline-flex items-center gap-1.5 text-sm font-medium text-gray-400 hover:text-gray-700 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Voltar
          <% end %>

          <button type="submit"
                  class="merma-btn-primary inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Enviar respostas
          </button>
        </div>
      <% end %>
      </div>
    <% end %>
  </div>
</div>

<% unless review_mode %>
  <script>
    document.addEventListener('turbo:load', function () {
      const form  = document.getElementById('merma-quiz-form');
      const bar   = document.getElementById('merma-quiz-bar');
      const label = document.getElementById('quiz-progress-label');
      const total = <%= questions.count %>;
      if (!form) return;

      function updateProgress() {
        const answered = new Set(
          Array.from(form.querySelectorAll('.merma-radio:checked'))
              .map(function (r) { return r.name; })
        ).size;
        const pct = total > 0 ? (answered / total * 100).toFixed(1) : 0;
        if (bar)   bar.style.width = pct + '%';
        if (label) label.textContent = answered + ' de ' + total + ' respondidas';
      }

      form.querySelectorAll('.merma-option').forEach(function (opt) {
        opt.addEventListener('click', function (event) {
          event.preventDefault();
          event.stopPropagation();

          const qid   = opt.dataset.question;
          const radio = opt.querySelector('.merma-radio');
          if (!radio) return;
          radio.checked = true;

          document.querySelectorAll('[data-question="' + qid + '"]').forEach(function (o) {
            const sel    = o === opt;
            const dot    = o.querySelector('.option-dot');
            const circle = o.querySelector('span.w-4');
            o.classList.toggle('border-[var(--color-primary)]',      sel);
            o.classList.toggle('bg-[var(--color-primary)\\/5]',      sel);
            o.classList.toggle('border-gray-200',                    !sel);
            if (circle) {
              circle.classList.toggle('border-[var(--color-primary)]', sel);
              circle.classList.toggle('border-gray-300',              !sel);
            }
            if (dot) {
              dot.classList.toggle('scale-100', sel);
              dot.classList.toggle('opacity-100', sel);
              dot.classList.toggle('scale-0', !sel);
              dot.classList.toggle('opacity-0', !sel);
            }
          });

          updateProgress();
        });
      });

      updateProgress();
    });
  </script>
<% end %>
