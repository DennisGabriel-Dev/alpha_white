<%# Formulário de prova (new e edit) %>

<%= form_with model: quiz, url: course_session_lesson_quiz_path(@course, @session, @lesson), method: quiz.persisted? ? :patch : :post, local: true, class: "space-y-4" do |f| %>
  <% if quiz.errors.any? %>
    <div class="p-4 bg-red-50 border-l-4 border-red-500 rounded-lg">
      <h4 class="font-semibold text-red-800 mb-2">Verifique os erros:</h4>
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% quiz.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Título da prova", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :title,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent",
        placeholder: "Ex: Prova Módulo 1",
        autofocus: true %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= f.submit class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancelar", course_session_lesson_path(@course, @session, @lesson), class: "text-gray-600 hover:text-gray-800 font-medium" %>
  </div>
<% end %>
