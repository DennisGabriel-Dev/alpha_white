<div class="container mx-auto px-4 py-8 max-w-3xl">
  <div class="mb-6">
    <%= link_to "← Voltar para prova", enem_exam_path(@enem_exam), class: "text-sm text-gray-600 hover:text-gray-800" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-4">
    <h1 class="text-2xl font-bold text-gray-800 mb-4">Editar prova ENEM</h1>

    <%= form_with model: @enem_exam, url: enem_exam_path(@enem_exam), method: :patch, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :year, "Ano", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :year, class: "w-full border border-gray-300 rounded-md p-2" %>
      </div>

      <div>
        <%= f.label :day, "Dia", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :day, EnemExam::DAY_VALUES, {}, class: "w-full border border-gray-300 rounded-md p-2" %>
      </div>

      <div>
        <%= f.label :booklet_color, "Cor do caderno", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :booklet_color, class: "w-full border border-gray-300 rounded-md p-2" %>
      </div>

      <div>
        <%= f.label :metadata_json, "Metadata (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :metadata_json, value: JSON.pretty_generate(@enem_exam.metadata || {}), rows: 8, class: "w-full border border-gray-300 rounded-md p-2 font-mono text-sm" %>
      </div>

      <div>
        <%= f.submit "Salvar prova", class: "px-4 py-2 rounded bg-primary text-white hover:opacity-90" %>
      </div>
    <% end %>
  </div>
</div>
