<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Biblioteca ENEM</h1>
      <p class="text-gray-500 text-sm mt-1">Provas oficiais importadas (global) para auditoria e edição.</p>
    </div>
    <%= link_to "Meus imports", enem_import_jobs_path, class: "px-4 py-2 rounded border border-gray-300 text-gray-700 hover:bg-gray-50" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left font-semibold text-gray-600">Ano</th>
          <th class="px-4 py-2 text-left font-semibold text-gray-600">Dia</th>
          <th class="px-4 py-2 text-left font-semibold text-gray-600">Caderno</th>
          <th class="px-4 py-2 text-left font-semibold text-gray-600">Questões</th>
          <th class="px-4 py-2 text-left font-semibold text-gray-600">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if @enem_exams.any? %>
          <% @enem_exams.each do |exam| %>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-2"><%= exam.year %></td>
              <td class="px-4 py-2"><%= exam.day %></td>
              <td class="px-4 py-2"><%= exam.booklet_color %></td>
              <td class="px-4 py-2"><%= exam.enem_questions.size %></td>
              <td class="px-4 py-2">
                <div class="flex gap-2">
                  <%= link_to "Ver", enem_exam_path(exam), class: "text-primary hover:underline" %>
                  <%= link_to "Editar", edit_enem_exam_path(exam), class: "text-gray-700 hover:underline" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-4 py-6 text-center text-gray-500">Nenhuma prova ENEM importada ainda.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
