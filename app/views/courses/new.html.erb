<%# Novo curso – adapta ao tema ativo %>

<% if themed_layout? %>
  <%# Temas com layout próprio (aurora, merma…) %>
  <% content_for :breadcrumb do %>
    <nav class="flex items-center gap-1.5 text-sm text-gray-400">
      <%= link_to "Cursos", courses_path, class: "hover:text-gray-700 transition-colors" %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="font-semibold text-gray-800">Novo curso</span>
    </nav>
  <% end %>

  <div class="max-w-xl mx-auto p-6">
    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <h1 class="text-base font-bold text-gray-900 mb-5">Novo curso</h1>
      <%= render "form", course: @course %>
    </div>
  </div>

<% else %>
  <%# Tema padrão %>
  <%= render "shared/header" %>

  <div class="container mx-auto px-4 py-8 max-w-xl">
    <nav class="mb-6">
      <%= link_to courses_path, class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
        <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
        Voltar para Cursos
      <% end %>
    </nav>
    <div class="card">
      <h1 class="text-xl font-bold text-gray-800 mb-6">Novo curso</h1>
      <%= render "form", course: @course %>
    </div>
  </div>

  <%= render "shared/footer" %>
<% end %>
