<% content_for :header_title, @course.name %>
<% content_for :header_subtitle, "Detalhes do curso" %>
<% content_for :main_class, "overflow-hidden flex flex-col" %>

<div class="flex flex-1 overflow-hidden">

  <%# Coluna principal %>
  <div class="flex-1 overflow-y-auto p-6 min-w-0">

    <%# Breadcrumb %>
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-5">
      <%= link_to courses_path, class: "hover:text-gray-600 transition-colors" do %>Cursos<% end %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-gray-600 font-medium"><%= @course.name %></span>
    </nav>

    <%# Badges %>
    <div class="flex flex-wrap items-center gap-2 mb-5">
      <span class="px-3 py-1 rounded-full text-xs font-semibold <%= @course.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
        <%= @course.active ? "Ativo" : "Em breve" %>
      </span>
      <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">
        <%= pluralize(@sessions.count, "módulo", "módulos") %>
      </span>
      <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">
        <%= pluralize(@all_lessons.count, "aula", "aulas") %>
      </span>
    </div>

    <%# Thumbnail / player do curso %>
    <div class="relative w-full rounded-2xl overflow-hidden mb-6"
         style="aspect-ratio: 16/9; background: linear-gradient(135deg, <%= tenant_primary_color %>, color-mix(in srgb, <%= tenant_primary_color %> 60%, black));">
      <div class="absolute inset-0 flex items-center justify-center">
        <% if @first_lesson.present? %>
          <%= link_to course_session_lesson_path(@course, @first_lesson.session, @first_lesson),
                class: "flex flex-col items-center gap-3 group" do %>
            <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur flex items-center justify-center group-hover:bg-white/30 transition-colors">
              <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <span class="text-white/80 text-sm font-medium">Assistir <%= @first_lesson.name %></span>
          <% end %>
        <% else %>
          <div class="text-white/40 text-center">
            <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
            </svg>
            <p class="text-sm">Nenhuma aula disponível ainda</p>
          </div>
        <% end %>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>
    </div>

    <%# Título e descrição %>
    <h1 class="text-2xl font-bold text-gray-900 mb-3"><%= @course.name %></h1>
    <% if @course.description.present? %>
      <p class="text-gray-500 leading-relaxed text-sm mb-6"><%= @course.description %></p>
    <% end %>

    <%# Ações %>
    <div class="flex flex-wrap gap-3 mb-8">
      <% if @first_lesson.present? %>
        <%= link_to course_session_lesson_path(@course, @first_lesson.session, @first_lesson),
              class: "aurora-btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors" do %>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          Iniciar curso
        <% end %>
      <% end %>
      <% if admin_or_instructor? %>
        <%= link_to new_course_session_path(@course),
              class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border border-gray-200 bg-white text-gray-700 hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Nova sessão
        <% end %>
      <% end %>
    </div>

    <% if notice %>
      <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm"><%= notice %></div>
    <% end %>

  </div>

  <%= render "shared/aurora/lesson_playlist",
        course: @course,
        sessions: @sessions,
        all_lessons: @all_lessons,
        completions: @completions %>

</div>
