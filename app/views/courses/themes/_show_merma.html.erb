<%# Course show – Merma
    Sidebar: course nav tree
    Main: visão geral do curso
    Right panel: study progress %>

<%# ── Sidebar: árvore de sessões ── %>
<% content_for :sidebar_content do %>
  <%= render "shared/merma/course_nav",
        course: @course,
        sessions: @sessions,
        all_lessons: @all_lessons,
        completions: @completions %>
<% end %>

<%# ── Right panel: progresso ── %>
<% content_for :right_panel do %>
  <%= render "shared/merma/study_progress",
        course: @course,
        sessions: @sessions,
        all_lessons: @all_lessons,
        completions: @completions %>
<% end %>

<%# ── Breadcrumb no header ── %>
<% content_for :breadcrumb do %>
  <nav class="flex items-center gap-1.5 text-sm text-gray-400">
    <%= link_to "Cursos", courses_path, class: "hover:text-gray-700 transition-colors" %>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-800 font-semibold truncate max-w-[16rem]"><%= @course.name %></span>
  </nav>
<% end %>

<%# ── Ações no header ── %>
<% content_for :header_actions do %>
  <div class="flex items-center gap-2">
    <% if @first_lesson.present? %>
      <%= link_to course_session_lesson_path(@course, @first_lesson.session, @first_lesson),
            class: "merma-btn-primary inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs font-semibold" do %>
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        Iniciar curso
      <% end %>
    <% end %>
    <% if admin_or_instructor? %>
      <%= link_to new_course_session_path(@course),
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nova sessão
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ── Conteúdo principal ── %>
<div class="h-full overflow-y-auto">

  <%# Thumbnail do curso %>
  <div class="relative w-full overflow-hidden"
       style="aspect-ratio: 16/9; max-height: 320px;">
    <div class="absolute inset-0 flex items-center justify-center"
         style="background: linear-gradient(135deg, var(--color-primary-10), white);">
      <% if @first_lesson.present? %>
        <%= link_to course_session_lesson_path(@course, @first_lesson.session, @first_lesson),
              class: "flex flex-col items-center gap-3 group" do %>
          <div class="w-16 h-16 rounded-full flex items-center justify-center shadow-lg transition-transform group-hover:scale-105"
               style="background: var(--color-primary);">
            <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <p class="text-sm font-medium text-gray-600">Assistir: <%= @first_lesson.name %></p>
        <% end %>
      <% else %>
        <div class="text-center text-gray-300">
          <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
          </svg>
          <p class="text-sm">Nenhuma aula disponível</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Info do curso %>
  <div class="p-6">
    <div class="flex flex-wrap gap-2 mb-3">
      <span class="text-xs px-2.5 py-1 rounded-full font-medium
                   <%= @course.active ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>">
        <%= @course.active ? "Ativo" : "Em breve" %>
      </span>
      <span class="text-xs px-2.5 py-1 rounded-full font-medium bg-gray-100 text-gray-600">
        <%= pluralize(@sessions.count, "módulo", "módulos") %>
      </span>
      <span class="text-xs px-2.5 py-1 rounded-full font-medium bg-gray-100 text-gray-600">
        <%= pluralize(@all_lessons.count, "aula", "aulas") %>
      </span>
    </div>

    <h1 class="text-xl font-bold text-gray-900 mb-2"><%= @course.name %></h1>

    <% if @course.description.present? %>
      <p class="text-sm text-gray-500 leading-relaxed"><%= @course.description %></p>
    <% end %>
  </div>

</div>
