<%# Página de detalhes do curso com lista de sessões %>

<%= render "shared/header" %>

<div class="container mx-auto px-4 py-8">
  <%# Breadcrumb %>
  <nav class="mb-6">
    <%= link_to courses_path, class: "inline-flex items-center text-gray-600 hover:text-primary transition-colors" do %>
      <%= heroicon(:arrow_left, css_class: "w-5 h-5 mr-2") %>
      Voltar para cursos
    <% end %>
  </nav>

  <%# Flash %>
  <% if notice %>
    <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-lg text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <%# Card do Curso %>
  <div class="card mb-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-2">
          <span class="px-3 py-1 rounded-full text-xs font-semibold <%= @course.active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
            <%= @course.active ? "Ativo" : "Em breve" %>
          </span>
        </div>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">
          <%= @course.name %>
        </h1>
        <% if @course.description.present? %>
          <p class="text-gray-600 leading-relaxed">
            <%= @course.description %>
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <%# Sessões %>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h2 class="text-xl font-bold text-gray-800">
      Sessões
      <% if @course.sessions.any? %>
        <span class="text-gray-500 font-normal text-base ml-2">(<%= @course.sessions.count %>)</span>
      <% end %>
    </h2>
    <% if admin_or_instructor? %>
      <%= link_to new_course_session_path(@course), class: "btn-primary inline-flex items-center" do %>
        <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
        Nova sessão
      <% end %>
    <% end %>
  </div>

  <% if @course.sessions.any? %>
    <div class="space-y-4">
      <% @course.sessions.each_with_index do |session, index| %>
        <div class="card flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold">
              <%= index + 1 %>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800">
                <%= session.name %>
              </h3>
              <!-- <p class="text-sm text-gray-500">
                Posição: <%#= session.position %>
              </p> -->
            </div>
          </div>
          <% if admin_or_instructor? %>
            <div class="flex items-center gap-2">
              <%= link_to edit_course_session_path(@course, session), class: "px-4 py-2 text-sm font-medium text-primary border border-primary rounded-lg hover:bg-primary/5 transition-colors" do %>
                <%= heroicon(:pencil, css_class: "w-4 h-4 inline-block mr-1") %>
                Editar
              <% end %>
              <%= button_to course_session_path(@course, session), method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover esta sessão?" }, class: "px-4 py-2 text-sm font-medium text-red-600 border border-red-300 rounded-lg hover:bg-red-50 transition-colors" do %>
                <%= heroicon(:trash, css_class: "w-4 h-4 inline-block mr-1") %>
                Remover
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <span class="text-5xl mb-4 inline-block">📂</span>
      <h3 class="text-lg font-semibold text-gray-700 mb-2">
        Nenhuma sessão cadastrada
      </h3>
      <p class="text-gray-500 mb-4">
        <%= admin_or_instructor? ? "Adicione a primeira sessão para organizar o conteúdo do curso." : "As sessões serão exibidas aqui quando forem cadastradas." %>
      </p>
      <% if admin_or_instructor? %>
        <%= link_to new_course_session_path(@course), class: "btn-primary inline-flex items-center" do %>
          <%= heroicon(:plus, css_class: "w-5 h-5 mr-2") %>
          Nova sessão
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<%= render "shared/footer" %>
