<%# Formulário de curso (new e edit) – funciona em qualquer tema %>

<%= form_with model: course, local: true, class: "space-y-5" do |f| %>

  <% if course.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700">
      <p class="font-semibold mb-1">Verifique os erros:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% course.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Nome %>
  <div>
    <%= f.label :name, "Nome do curso", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
    <%= f.text_field :name,
          class: "w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl bg-white
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-primary,#6366f1)]/30 focus:border-[var(--color-primary,#6366f1)]
                  placeholder:text-gray-400",
          placeholder: "Ex: Matemática para o ENEM",
          autofocus: true %>
  </div>

  <%# Descrição %>
  <div>
    <%= f.label :description, "Descrição", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
    <%= f.text_area :description,
          class: "w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl bg-white
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-primary,#6366f1)]/30 focus:border-[var(--color-primary,#6366f1)]
                  placeholder:text-gray-400 resize-none",
          rows: 4,
          placeholder: "Descreva o conteúdo do curso (opcional, máx. 1000 caracteres)" %>
    <p class="text-xs text-gray-400 mt-1" id="desc-counter">0 / 1000</p>
  </div>

  <%# Status %>
  <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl border border-gray-200">
    <div>
      <p class="text-sm font-semibold text-gray-700">Curso ativo</p>
      <p class="text-xs text-gray-400 mt-0.5">Cursos ativos aparecem para os alunos</p>
    </div>
    <label class="relative inline-flex items-center cursor-pointer">
      <%= f.check_box :active,
            class: "sr-only peer",
            id: "course_active_toggle" %>
      <div class="w-10 h-5 bg-gray-300 peer-checked:bg-[var(--color-primary,#6366f1)]
                  rounded-full transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5
                  after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-transform
                  peer-checked:after:translate-x-5"></div>
    </label>
  </div>

  <%# Ações %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit course.persisted? ? "Salvar alterações" : "Criar curso",
          class: "px-6 py-2.5 text-sm font-semibold text-white rounded-xl cursor-pointer transition-opacity hover:opacity-90",
          style: "background: var(--color-primary, #6366f1);" %>

    <% back_path = course.persisted? ? course_path(course) : courses_path %>
    <%= link_to "Cancelar", back_path,
          class: "px-4 py-2.5 text-sm font-medium text-gray-500 hover:text-gray-800 transition-colors" %>
  </div>

<% end %>

<script>
  document.addEventListener('turbo:load', function () {
    const textarea = document.querySelector('textarea[name="course[description]"]');
    const counter  = document.getElementById('desc-counter');
    if (!textarea || !counter) return;
    function update() { counter.textContent = textarea.value.length + ' / 1000'; }
    textarea.addEventListener('input', update);
    update();
  });
</script>
