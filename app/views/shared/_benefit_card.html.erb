<%# Benefit Card Component
     Card individual de benefício
     Props: icon, title, description %>

<div class="card text-center hover:scale-105 transition-transform duration-200">
  <%# Ícone %>
  <div class="mx-auto mb-4 w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center">
    <%= heroicon(icon, css_class: "w-8 h-8") %>
  </div>
  
  <%# Título %>
  <h3 class="text-xl font-bold text-gray-800 mb-3">
    <%= title %>
  </h3>
  
  <%# Descrição %>
  <p class="text-gray-600 leading-relaxed">
    <%= description %>
  </p>
</div>
