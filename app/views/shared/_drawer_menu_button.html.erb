<%# locals: toggle_id (required), backdrop_id (required), label: "Menu" %>
<button type="button"
        class="lg:hidden p-2 -ml-1 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors flex-shrink-0"
        id="<%= toggle_id %>-btn"
        data-drawer-toggle="<%= toggle_id %>"
        data-drawer-backdrop="<%= backdrop_id %>"
        aria-expanded="false"
        aria-label="<%= local_assigns[:label] || 'Menu' %>">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
  </svg>
</button>
