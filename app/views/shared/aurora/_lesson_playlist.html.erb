<%# Playlist lateral de aulas – Aurora
    Locals:
      course         – Course
      sessions       – sessions.order(:position).includes(:lessons)
      all_lessons    – sessions.flat_map(&:lessons)
      completions    – { lesson_id => LessonCompletion }
      current_lesson – Lesson atual (opcional, para highlight) %>

<aside id="aurora-lesson-playlist"
       class="fixed inset-y-0 right-0 z-40 w-80 max-w-[90vw] flex-shrink-0 border-l border-gray-100 bg-white flex flex-col overflow-hidden
              translate-x-full xl:static xl:z-auto xl:max-w-none xl:translate-x-0
              transition-transform duration-200 ease-out"
       data-drawer-closed-class="translate-x-full"
       data-drawer-open-class="translate-x-0">

  <%# Cabeçalho %>
  <div class="px-5 pt-5 pb-3 border-b border-gray-100 flex items-center justify-between">
    <div>
      <h2 class="text-sm font-semibold text-gray-900">Playlist de aulas</h2>
      <p class="text-xs text-gray-400 mt-0.5">
        <%= all_lessons.count { |l| completions[l.id]&.completed? } %> /
        <%= all_lessons.count %> concluídas
      </p>
    </div>
    <%# Barra de progresso %>
    <% pct = all_lessons.any? ? (all_lessons.count { |l| completions[l.id]&.completed? } * 100.0 / all_lessons.count).round : 0 %>
    <div class="w-10 h-10 relative flex-shrink-0">
      <svg class="w-10 h-10 -rotate-90" viewBox="0 0 36 36">
        <circle cx="18" cy="18" r="15" fill="none" stroke="#f3f4f6" stroke-width="3"/>
        <circle cx="18" cy="18" r="15" fill="none" stroke="var(--color-primary)"
                stroke-width="3"
                stroke-dasharray="<%= (pct * 94.25 / 100).round(1) %>, 94.25"
                stroke-linecap="round"/>
      </svg>
      <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-gray-700"><%= pct %>%</span>
    </div>
  </div>

  <%# Busca %>
  <div class="px-4 py-3 border-b border-gray-100">
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input type="text" placeholder="Buscar aulas..." id="playlist-search"
             class="w-full pl-9 pr-3 py-2 text-xs bg-gray-50 border border-gray-100 rounded-lg
                    focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30">
    </div>
  </div>

  <%# Lista %>
  <div class="flex-1 overflow-y-auto" id="playlist-list">
    <% lesson_number = 0 %>
    <% sessions.each do |session| %>

      <div class="px-4 pt-4 pb-1 flex items-center justify-between gap-2">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider truncate flex-1 min-w-0"><%= session.name %></p>
        <% if admin_or_instructor? %>
          <div class="flex items-center gap-0.5 flex-shrink-0">
            <%= link_to edit_course_session_path(course, session),
                  title: "Editar sessão",
                  class: "w-5 h-5 rounded flex items-center justify-center text-gray-300
                          hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125"/>
              </svg>
            <% end %>
            <%= link_to new_course_session_lesson_path(course, session),
                  title: "Nova aula",
                  class: "w-5 h-5 rounded flex items-center justify-center text-gray-300
                          hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>

      <% session.lessons.order(:position).each do |lesson| %>
        <% lesson_number += 1 %>
        <% completion    = completions[lesson.id] %>
        <% is_completed  = completion&.completed? %>
        <% is_current    = defined?(current_lesson) && current_lesson&.id == lesson.id %>

        <%= link_to course_session_lesson_path(course, session, lesson),
              class: [
                "flex items-center gap-3 px-4 py-3 transition-colors border-b border-gray-50 playlist-item",
                is_current ? "bg-[var(--color-primary)]/5 border-l-2 border-l-[var(--color-primary)]" : "hover:bg-gray-50"
              ].join(" "),
              "data-name": lesson.name.downcase do %>

          <div class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center
                      <%= is_completed ? 'bg-[var(--color-primary)]/10 text-[var(--color-primary)]'
                                       : is_current  ? 'bg-[var(--color-primary)] text-white'
                                                     : 'bg-gray-100 text-gray-400' %>">
            <% if is_completed %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            <% else %>
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            <% end %>
          </div>

          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium truncate playlist-name
                       <%= is_current ? 'text-[var(--color-primary)]' : 'text-gray-800' %>">
              <%= lesson_number %>. <%= lesson.name %>
            </p>
            <p class="text-xs mt-0.5
                       <%= is_completed ? 'text-[var(--color-primary)]'
                                        : is_current ? 'text-[var(--color-primary)]/70'
                                                     : 'text-gray-400' %>">
              <%= is_completed ? "Concluída" : is_current ? "Assistindo" : "Não iniciada" %>
            </p>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <% if all_lessons.empty? %>
      <div class="flex flex-col items-center justify-center py-12 px-4 text-center">
        <svg class="w-8 h-8 text-gray-200 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
        </svg>
        <p class="text-xs text-gray-400">Nenhuma aula cadastrada</p>
      </div>
    <% end %>
  </div>

</aside>

<script>
  document.addEventListener('turbo:load', function () {
    const input = document.getElementById('playlist-search');
    if (!input) return;
    input.addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.playlist-item').forEach(function (item) {
        item.style.display = item.dataset.name.includes(q) ? '' : 'none';
      });
    });
  });
</script>
