<script>
  document.addEventListener('turbo:load', function () {
    document.querySelectorAll('[data-drawer-toggle]').forEach(function (btn) {
      if (btn.dataset.drawerBound === '1') return;
      btn.dataset.drawerBound = '1';

      var panelId = btn.getAttribute('data-drawer-toggle');
      var panel = document.getElementById(panelId);
      var backdrop = document.getElementById(btn.getAttribute('data-drawer-backdrop'));
      if (!panel) return;

      var closedClasses = (panel.getAttribute('data-drawer-closed-class') || '-translate-x-full').split(/\s+/);
      var openClasses = (panel.getAttribute('data-drawer-open-class') || 'translate-x-0').split(/\s+/);

      function isOpen() {
        return openClasses.every(function (c) { return panel.classList.contains(c); });
      }

      function setOpen(open) {
        closedClasses.forEach(function (c) { panel.classList.toggle(c, !open); });
        openClasses.forEach(function (c) { panel.classList.toggle(c, open); });
        if (backdrop) backdrop.classList.toggle('hidden', !open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      btn.addEventListener('click', function () {
        setOpen(!isOpen());
      });

      if (backdrop) {
        backdrop.addEventListener('click', function () { setOpen(false); });
      }

      panel.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          if (window.matchMedia('(max-width: 1023px)').matches) setOpen(false);
        });
      });
    });
  });
</script>
