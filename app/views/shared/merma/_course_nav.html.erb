<%# Sidebar de navegação do curso (árvore de sessões/aulas) – Merma
    Locals:
      course         – Course
      sessions       – sessions ordenadas com :lessons incluídas
      all_lessons    – flat list
      completions    – { lesson_id => LessonCompletion }
      current_lesson – Lesson atual (opcional, para highlight) %>

<%# Header do curso %>
<div class="px-4 pt-4 pb-2 flex-shrink-0 border-b border-gray-200">
  <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wide mb-1">Curso</p>
  <p class="text-xs font-semibold text-gray-900 leading-snug"><%= course.name %></p>
  <% done  = all_lessons.count { |l| completions[l.id]&.completed? } %>
  <% total = all_lessons.count %>
  <% pct   = total > 0 ? (done * 100.0 / total).round : 0 %>
  <div class="flex items-center gap-2 mt-2">
    <div class="flex-1 h-1 bg-gray-200 rounded-full overflow-hidden">
      <div class="h-full rounded-full transition-all"
           style="width: <%= pct %>%; background: var(--color-primary);"></div>
    </div>
    <span class="text-[10px] text-gray-400 flex-shrink-0"><%= done %>/<%= total %></span>
  </div>
</div>

<%# Busca %>
<div class="px-3 py-2 flex-shrink-0">
  <div class="relative">
    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3 h-3 text-gray-400"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input type="text" placeholder="Buscar aulas..."
           id="merma-course-nav-search"
           class="w-full pl-7 pr-2 py-1.5 text-[11px] bg-white border border-gray-200 rounded-lg
                  focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)]/30">
  </div>
</div>

<%# Árvore de sessões %>
<div class="flex-1 overflow-y-auto px-2 pb-4" id="merma-course-nav-list">
  <% lesson_num = 0 %>
  <% sessions.each do |session| %>
    <div class="mb-1">
      <%# Cabeçalho da sessão %>
      <div class="flex items-center justify-between gap-1 px-2 pt-3 pb-1">
        <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider truncate flex-1 min-w-0">
          <%= session.name %>
        </p>
        <% if admin_or_instructor? %>
          <div class="flex items-center gap-0.5 flex-shrink-0">
            <%= link_to edit_course_session_path(course, session),
                  title: "Editar sessão",
                  class: "w-4 h-4 flex items-center justify-center rounded text-gray-300
                          hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-colors" do %>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125"/>
              </svg>
            <% end %>
            <%= link_to new_course_session_lesson_path(course, session),
                  title: "Nova aula",
                  class: "w-4 h-4 flex items-center justify-center rounded text-gray-300
                          hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-colors" do %>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Aulas %>
      <% session.lessons.order(:position).each do |lesson| %>
        <% lesson_num += 1 %>
        <% comp        = completions[lesson.id] %>
        <% is_done     = comp&.completed? %>
        <% is_current  = defined?(current_lesson) && current_lesson&.id == lesson.id %>

        <%= link_to course_session_lesson_path(course, session, lesson),
              class: "merma-nav-item merma-course-nav-item #{is_current ? 'active' : ''}",
              "data-name": lesson.name.downcase do %>
          <%# Ícone de status %>
          <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0
                       <%= is_done ? 'bg-[var(--color-primary)]/10' : is_current ? 'bg-[var(--color-primary)]' : 'bg-gray-100' %>">
            <% if is_done %>
              <svg class="w-3 h-3 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            <% elsif is_current %>
              <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            <% else %>
              <span class="text-[9px] font-semibold text-gray-400"><%= lesson_num %></span>
            <% end %>
          </span>
          <span class="truncate text-[12px]"><%= lesson.name %></span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if all_lessons.empty? %>
    <p class="text-[11px] text-gray-400 text-center py-8">Nenhuma aula cadastrada</p>
  <% end %>
</div>

<script>
  document.addEventListener('turbo:load', function () {
    const input = document.getElementById('merma-course-nav-search');
    if (!input) return;
    input.addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.merma-course-nav-item').forEach(function (el) {
        el.style.display = el.dataset.name.includes(q) ? '' : 'none';
      });
    });
  });
</script>
