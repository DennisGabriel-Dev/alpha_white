<%# Painel direito: Study Progress + Course Content – Merma
    Locals:
      course         – Course
      sessions       – sessions.includes(:lessons)
      all_lessons    – flat list
      completions    – { lesson_id => LessonCompletion }
      current_lesson – Lesson atual (opcional) %>

<%# Study Progress card %>
<div class="p-5 border-b border-gray-100">
  <div class="flex items-start gap-4">
    <% done  = all_lessons.count { |l| completions[l.id]&.completed? } %>
    <% total = all_lessons.count %>
    <% pct   = total > 0 ? (done * 100.0 / total).round : 0 %>

    <%= render "shared/merma/progress_ring", pct: pct, size: 72, stroke_width: 6 %>

    <div class="flex-1 min-w-0">
      <p class="text-sm font-semibold text-gray-900">Progresso do estudo</p>
      <p class="text-xs text-gray-400 mt-1 leading-relaxed">
        Acompanhe suas aulas e continue de onde parou.
      </p>
      <p class="text-xs font-medium mt-2" style="color: var(--color-primary);">
        <%= done %> de <%= total %> aulas concluídas
      </p>
    </div>
  </div>
</div>

<%# Course Content list %>
<div class="px-4 pt-4 pb-2 flex items-center justify-between">
  <p class="text-xs font-semibold text-gray-900">Conteúdo do curso</p>
  <span class="text-[10px] text-gray-400"><%= total %> aulas</span>
</div>

<div class="flex-1 overflow-y-auto px-3 pb-4">
  <% lesson_num = 0 %>
  <% sessions.each do |session| %>
    <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider px-1 pt-3 pb-1">
      <%= session.name %>
    </p>
    <% session.lessons.order(:position).each do |lesson| %>
      <% lesson_num += 1 %>
      <% comp       = completions[lesson.id] %>
      <% is_done    = comp&.completed? %>
      <% is_current = defined?(current_lesson) && current_lesson&.id == lesson.id %>
      <% lesson_pct = is_done ? 100 : (comp.present? ? 50 : 0) %>

      <%= link_to course_session_lesson_path(course, session, lesson),
            class: "flex items-center gap-3 px-2 py-2.5 rounded-xl transition-colors group
                    #{is_current ? 'bg-[var(--color-primary)]/5' : 'hover:bg-gray-50'}" do %>

        <span class="text-[11px] font-medium text-gray-400 w-4 flex-shrink-0 text-right">
          <%= lesson_num %>
        </span>

        <div class="flex-1 min-w-0">
          <p class="text-xs font-medium truncate
                     <%= is_current ? 'text-[var(--color-primary)]' : 'text-gray-700' %>">
            <%= lesson.name %>
          </p>
        </div>

        <%# Pequeno ring de progresso por aula %>
        <% if is_done %>
          <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0
                       bg-[var(--color-primary)]/10">
            <svg class="w-3 h-3 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
        <% elsif comp.present? %>
          <%= render "shared/merma/progress_ring", pct: 50, size: 20, stroke_width: 2.5, show_text: false %>
        <% else %>
          <span class="w-5 h-5 rounded-full border-2 border-gray-200 flex-shrink-0"></span>
        <% end %>

      <% end %>
    <% end %>
  <% end %>
</div>
