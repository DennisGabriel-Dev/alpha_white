<%# Sidebar padrão do Merma – lista de cursos disponíveis
    Usado quando nenhuma página injeta :sidebar_content %>

<%# Header %>
<div class="px-4 pt-4 pb-2 flex items-center justify-between flex-shrink-0">
  <div>
    <p class="text-xs font-semibold text-gray-900">Cursos</p>
    <p class="text-[10px] text-gray-400 mt-0.5">All <%= merma_nav_courses.count %></p>
  </div>
</div>

<%# Busca %>
<div class="px-3 pb-2 flex-shrink-0">
  <div class="relative">
    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input type="text" placeholder="Buscar..."
           id="merma-sidebar-search"
           class="w-full pl-8 pr-3 py-1.5 text-xs bg-white border border-gray-200 rounded-lg
                  focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)]/30">
  </div>
</div>

<%# Lista de cursos %>
<div class="flex-1 overflow-y-auto px-2 pb-4" id="merma-sidebar-list">
  <% merma_nav_courses.each_with_index do |course, i| %>
    <% color = merma_course_color(i) %>
    <%= link_to course_path(course),
          class: "merma-nav-item merma-sidebar-course-item #{controller_name == 'courses' && params[:id].to_s == course.id.to_s ? 'active' : ''}",
          "data-name": course.name.downcase do %>
      <span class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold flex-shrink-0"
            style="background: <%= color[:bg] %>; color: <%= color[:text] %>;">
        <%= course.name.first.upcase %>
      </span>
      <span class="truncate"><%= course.name %></span>
    <% end %>
  <% end %>

  <% if merma_nav_courses.empty? %>
    <p class="text-[11px] text-gray-400 text-center py-6">Nenhum curso disponível</p>
  <% end %>

  <% if me_achievements_path_allowed? %>
    <div class="px-2 pt-3 mt-2 border-t border-gray-100 space-y-0.5">
      <p class="px-2 pb-1 text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Você</p>
      <%= link_to me_achievements_path, class: "merma-nav-item #{controller_path == 'me/achievements' ? 'active' : ''}" do %>
        <%= heroicon(:trophy, css_class: "w-4 h-4 flex-shrink-0 text-gray-500") %>
        <span class="truncate flex-1">Conquistas</span>
      <% end %>
    </div>
  <% end %>

  <% if reports_aluno_path_allowed? || reports_turma_path_allowed? || reports_escola_path_allowed? %>
    <div class="px-2 pt-3 mt-2 border-t border-gray-100 space-y-0.5">
      <p class="px-2 pb-1 text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Relatórios</p>
      <% if reports_aluno_path_allowed? %>
        <%= link_to relatorios_aluno_path, class: "merma-nav-item #{controller_name == 'reports' && action_name == 'aluno' ? 'active' : ''}" do %>
          <%= heroicon(:chart_bar, css_class: "w-4 h-4 flex-shrink-0 text-gray-500") %>
          <span class="truncate">Meu desempenho</span>
        <% end %>
      <% end %>
      <% if reports_turma_path_allowed? %>
        <%= link_to relatorios_turma_path, class: "merma-nav-item #{controller_name == 'reports' && action_name == 'turma' ? 'active' : ''}" do %>
          <%= heroicon(:user_circle, css_class: "w-4 h-4 flex-shrink-0 text-gray-500") %>
          <span class="truncate">Turma</span>
        <% end %>
      <% end %>
      <% if reports_escola_path_allowed? %>
        <%= link_to relatorios_escola_path, class: "merma-nav-item #{controller_name == 'reports' && action_name == 'escola' ? 'active' : ''}" do %>
          <%= heroicon(:academic_cap, css_class: "w-4 h-4 flex-shrink-0 text-gray-500") %>
          <span class="truncate">Escola</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if staff_users_path_allowed? %>
    <div class="px-2 pt-3 mt-2 border-t border-gray-100 space-y-0.5">
      <p class="px-2 pb-1 text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Administração</p>
      <%= link_to staff_users_path, class: "merma-nav-item #{controller_name == 'staff_users' ? 'active' : ''}" do %>
        <%= heroicon(:user_circle, css_class: "w-4 h-4 flex-shrink-0 text-gray-500") %>
        <span class="truncate">Equipe</span>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('turbo:load', function () {
    const input = document.getElementById('merma-sidebar-search');
    if (!input) return;
    input.addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.merma-sidebar-course-item').forEach(function (el) {
        el.style.display = el.dataset.name.includes(q) ? '' : 'none';
      });
    });
  });
</script>
