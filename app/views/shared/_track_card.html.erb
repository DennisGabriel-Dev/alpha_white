<%# Track Card Component
     Card de trilha de estudos
     Props: name, description, courses_count, hours, level %>

<div class="card">
  <%# Header com ícone %>
  <div class="flex items-start space-x-4 mb-4">
    <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-accent-turquoise to-primary rounded-xl flex items-center justify-center text-3xl">
      🎯
    </div>
    
    <div class="flex-1">
      <h3 class="text-xl font-bold text-gray-800 mb-1">
        <%= name %>
      </h3>
      <p class="text-sm text-gray-600">
        <%= description %>
      </p>
    </div>
  </div>
  
  <%# Informações da trilha %>
  <div class="grid grid-cols-3 gap-4 py-4 border-t border-gray-200">
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">
        <%= courses_count %>
      </div>
      <div class="text-xs text-gray-500">
        Cursos
      </div>
    </div>
    
    <div class="text-center border-x border-gray-200">
      <div class="text-2xl font-bold text-primary">
        <%= hours %>h
      </div>
      <div class="text-xs text-gray-500">
        Duração
      </div>
    </div>
    
    <div class="text-center">
      <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">
        <%= level %>
      </span>
    </div>
  </div>
  
  <%# CTA %>
  <div class="pt-4">
    <% cta_path = local_assigns[:course] ? course_path(course) : courses_path %>
    <%= link_to cta_path, class: "block w-full text-center py-3 px-4 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-colors" do %>
      Ver curso →
    <% end %>
  </div>
</div>
