<%# Header/Navbar Component
     Navbar responsivo com logo do tenant, menu de navegação e CTAs %>

<header class="sticky top-0 z-50 bg-white shadow-md">
  <nav class="container mx-auto px-4 py-4">
    <div class="flex items-center justify-between">

      <%# Logo (whitelabel - dinâmico por tenant) %>
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <%# TODO: Adicionar logo do tenant quando implementado %>
          <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-xl">📚</span>
          </div>
          <span class="text-xl font-bold text-primary">
            <%= ActsAsTenant.current_tenant&.name || "Alpha White" %>
          </span>
        <% end %>
      </div>

      <%# Menu Desktop %>
      <div class="hidden md:flex items-center space-x-8">
        <%= link_to "Cursos", courses_path, class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Trilhas", "#trilhas", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Simulados", "#simulados", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Sobre", "#sobre", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
      </div>

      <%# CTAs Desktop %>
      <div class="hidden md:flex items-center space-x-4">
        <% if user_signed_in? %>
          <%= render "shared/icons/settings_icon" %>
          <%= link_to "Sair", destroy_user_session_path,
            data: {
              turbo_method: :delete,
              turbo_confirm: "Tem certeza que deseja sair?",
              turbo_confirm_message: "Tem certeza que deseja sair?"
            },
            class: "text-primary font-semibold hover:text-primary-dark transition-colors" 
          %>
        <% else %>
          <%= link_to "Entrar", new_user_session_path, class: "text-primary font-semibold hover:text-primary-dark transition-colors" %>
          <%= link_to "Começar Grátis", new_user_registration_path, class: "btn-primary" %>
        <% end %>
      </div>

      <%# Menu Mobile (Hamburguer) %>
      <button class="md:hidden text-gray-700" id="mobile-menu-button">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <%# Menu Mobile Dropdown %>
    <div class="hidden md:hidden mt-4 pb-4 border-t border-gray-200" id="mobile-menu">
      <div class="flex flex-col space-y-4 mt-4">
        <%= link_to "Cursos", courses_path, class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Trilhas", "#trilhas", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Simulados", "#simulados", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <%= link_to "Sobre", "#sobre", class: "text-gray-700 hover:text-primary font-medium transition-colors" %>
        <div class="pt-4 border-t border-gray-200 flex flex-col space-y-3">
          <% if user_signed_in? %>
            <%= render "shared/icons/settings_icon" %>
            <%= link_to "Sair", destroy_user_session_path, method: :delete, class: "text-center py-2 text-primary font-semibold hover:text-primary-dark transition-colors" %>
          <% else %>
            <%= link_to "Entrar", new_user_session_path, class: "text-center py-2 text-primary font-semibold hover:text-primary-dark transition-colors" %>
            <%= link_to "Começar Grátis", new_user_registration_path, class: "btn-primary text-center" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>
</header>

<%# JavaScript para toggle do menu mobile (usando Stimulus ou vanilla JS) %>
<script>
  document.getElementById('mobile-menu-button')?.addEventListener('click', function() {
    const menu = document.getElementById('mobile-menu');
    menu.classList.toggle('hidden');
  });
</script>
